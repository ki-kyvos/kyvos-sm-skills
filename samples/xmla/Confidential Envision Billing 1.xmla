                    "FROM EDW_INT.dbo.vf_gl_month ;"
                  ],
                  "dataSource": "EDW_INT"
                }
              }
            ],
            "measures": [
              {
                "name": "GL DB Amount",
                "expression": "SUM([db_amount])",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Lawson GL Actuals",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "GL CR Amount",
                "expression": "SUM([cr_amount])",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Lawson GL Actuals",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "GL Amount",
                "expression": "[GL DB Amount] + [GL CR Amount]",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Lawson GL Actuals",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Remove_ALE/Units",
                "expression": "CALCULATE(DIVIDE([GL Amount] , [Total Units], 0), 'GL Account'[Is ALE] = TRUE)",
                "formatString": "#,0.00",
                "isHidden": true
              },
              {
                "name": "Remove_GL Amount All Facilities",
                "expression": "CALCULATE([GL Amount], ALLEXCEPT(Facility, Facility[Fac LOB]))",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "isHidden": true,
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Remove_LOB ALE/Cases",
                "expression": "CALCULATE(DIVIDE([GL Amount],[Total Cases], 0), ALLEXCEPT('Facility','Facility'[Fac LOB]))",
                "formatString": "#,0.00",
                "isHidden": true
              },
              {
                "name": "Remove_OB ALE/Minutes",
                "expression": "CALCULATE(DIVIDE([GL Amount], [Total Minutes], 0), ALLEXCEPT('Facility',Facility[Fac LOB]))",
                "formatString": "#,0.00",
                "isHidden": true
              },
              {
                "name": "Remove_LOB ALE/Units",
                "expression": "CALCULATE(DIVIDE([GL Amount] , [Total Units], 0),ALLEXCEPT('Facility',Facility[Fac LOB]))",
                "formatString": "#,0.00",
                "isHidden": true
              },
              {
                "name": "GL DB Units",
                "expression": "SUM([db_units])",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "GL CR Units",
                "expression": "SUM([cr_units])",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "GL Units",
                "expression": "[GL DB Units] + [GL CR Units]",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "Gross Patient Service A/R",
                "expression": "CALCULATE([GL Amount],'Hyp Account Hier BS'[BS Parent Name]=\"Gross Patient Service A/R\", 'Date Of Service'[Serv Yr]<2018)",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "Gross Charges",
                "expression": "-CALCULATE([GL Amount],'Hyp Account Hier IS'[IS Parent Name]=\"Gross_Charges\")",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "ACPC Cost Per Case AVG",
                "expression": "DIVIDE([Gross Charges],CALCULATE([GL Units], 'Hyp Account Hier Stats'[member_name]=\"4000-0000\"),0)",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals\\DSO"
              },
              {
                "name": "Gross Patient Service A/R All Time",
                "expression": "CALCULATE([Gross Patient Service A/R],FILTER(ALL('Date Of Service'),'Date Of Service'[Serv Dte]<=MAX('Date Of Service'[Serv Dte])))",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals\\DSO"
              },
              {
                "name": "Gross Charges 90 Days",
                "expression": "CALCULATE([Gross Charges],DATESBETWEEN('Date Of Service'[Serv Dte],FIRSTDATE(DATEADD('Date Of Service'[Serv Dte],-2,MONTH)), MAX('Date Of Service'[Serv Dte])))",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "Gross DSO",
                "expression": "DIVIDE([Gross Patient Service A/R All Time],DIVIDE(([Gross Charges 90 Days]+[Estimated Charges A/R 90 Days]),90,0),0)",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals\\DSO"
              },
              {
                "name": "Estimated Charges A/R",
                "expression": "CALCULATE([GL Amount],'Hyp Account Hier BS'[BS Member Desc]=\"A/R ESTIMATED CHARGES\", 'Date Of Service'[Serv Yr]<2018)",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "Estimated Charges A/R 90 Days",
                "expression": "CALCULATE([Estimated Charges A/R],DATESBETWEEN('Date Of Service'[Serv Dte],FIRSTDATE(DATEADD('Date Of Service'[Serv Dte],-2,MONTH)), MAX('Date Of Service'[Serv Dte])))",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "Net Patient Service A/R All Time",
                "expression": [
                  "CALCULATE (",
                  "    [Net Patient Service A/R],",
                  "    FILTER (",
                  "        ALL ( 'Date Of Service' ),",
                  "        'Date Of Service'[Serv Dte] <= MAX ( 'Date Of Service'[Serv Dte] )",
                  "    )",
                  ")"
                ],
                "displayFolder": "Lawson GL Actuals\\DSO"
              },
              {
                "name": "Net Patient Service Revenue",
                "expression": [
                  "-CALCULATE (",
                  "    [GL Amount],",
                  "    FILTER (",
                  "        'Hyp Account Hier IS',",
                  "        LOOKUPVALUE (",
                  "            'Hyp Account Hier IS'[member_name],",
                  "            'Hyp Account Hier IS'[IS member num], VALUE ( PATHITEM ( 'Hyp Account Hier IS'[HierarchyPath], 10 ) )",
                  "        )",
                  "            = \"Net_Patient_Service_Revenue\"",
                  "    ),  'Date Of Service'[Serv Yr]<2018",
                  ")"
                ],
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Lawson GL Actuals",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Net Patient Service Revenue 90 Days",
                "expression": [
                  "CALCULATE (",
                  "    [Net Patient Service Revenue],",
                  "    DATESBETWEEN (",
                  "        'Date Of Service'[Serv Dte],",
                  "        FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -2, MONTH ) ),",
                  "        MAX ( 'Date Of Service'[Serv Dte] )",
                  "    )",
                  ")"
                ],
                "displayFolder": "Lawson GL Actuals\\DSO"
              },
              {
                "name": "Net DSO",
                "expression": "DIVIDE([Net Patient Service A/R All Time],DIVIDE([Net Patient Service Revenue 90 Days],90,0),BLANK())",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals\\DSO"
              },
              {
                "name": "Total Units - Norm for ALE Denom",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"TotalUnits - Nm\", [Total Units - Norm],",
                  "            \"GLAmount\", [GL Amount]",
                  "        ),",
                  "        AND ( [TotalUnits - Nm] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [Total Units - Norm]",
                  ")"
                ],
                "formatString": "#,0.00",
                "isHidden": true
              },
              {
                "name": "ALE/Units - Norm",
                "expression": "CALCULATE(DIVIDE([GL Amount for ALE - Norm Numer],[Total Units - Norm for ALE Denom],0),'GL Account'[Is ALE]= TRUE)",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "Net Patient Service A/R",
                "expression": [
                  "CALCULATE (",
                  "    [GL Amount],",
                  "    FILTER (",
                  "        'Hyp Account Hier BS',",
                  "        LOOKUPVALUE (",
                  "            'Hyp Account Hier BS'[member_name],",
                  "            'Hyp Account Hier BS'[BS member num], VALUE ( PATHITEM ( 'Hyp Account Hier BS'[HierarchyPath], 7 ) )",
                  "        )",
                  "            = \"A/R - Net Patient Service\"",
                  "    ),   'Date Of Service'[Serv Yr]<2018",
                  ")"
                ],
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Lawson GL Actuals\\DSO",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Collection%",
                "expression": "DIVIDE([Net Patient Service Revenue],[Gross Charges],0)",
                "displayFolder": "Lawson GL Actuals\\DSO"
              },
              {
                "name": "GL Amount for ALE - Norm Numer",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"TotalUnits - Nm\", [Total Units - Norm],",
                  "            \"GLAmount\", [GL Amount]",
                  "        ),",
                  "        AND ( [TotalUnits - Nm] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [GL Amount]",
                  ")"
                ],
                "isHidden": true
              },
              {
                "name": "Total Units for ALE Denom",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"TotalUnits\", [Total Units],",
                  "            \"GLAmount\", [GL Amount]",
                  "        ),",
                  "        AND ( [TotalUnits] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [Total Units]",
                  ")"
                ],
                "isHidden": true
              },
              {
                "name": "GL Amount for ALE Numer",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"TotalUnits\", [Total Units],",
                  "            \"GLAmount\", [GL Amount]",
                  "        ),",
                  "        AND ( [TotalUnits] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [GL Amount]",
                  ")"
                ],
                "isHidden": true
              },
              {
                "name": "ALE/Units",
                "expression": "CALCULATE(DIVIDE([GL Amount for ALE Numer],[Total Units for ALE Denom],0),'GL Account'[Is ALE]= TRUE)",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "ALE/Cases",
                "expression": "CALCULATE(DIVIDE([GL Amount  ALE/Cases Numer],[Total Cases  ALE/Cases Denom],0),'GL Account'[Is ALE]= TRUE)",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "ALE/Minutes",
                "expression": "DIVIDE([Total GL Amount for ALE/Min Numer], [Total Minutes for ALE/Min Denom],BLANK())",
                "formatString": "#,0.00",
                "displayFolder": "Lawson GL Actuals"
              },
              {
                "name": "ALE/Units - Norm1",
                "expression": [
                  "CALCULATE (",
                  "    DIVIDE ( [GL Amount], [Total Units - Norm] , 0 ),",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"TotalUnits\", [Total Units - Norm],",
                  "            \"GLAmount\", [GL Amount]",
                  "        ),",
                  "        AND ( [TotalUnits] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    'GL Account'[Is ALE] = TRUE()",
                  ")"
                ],
                "isHidden": true
              },
              {
                "name": "Gross DSO1",
                "expression": [
                  "CALCULATE (",
                  "    DIVIDE (",
                  "        [Gross Patient Service A/R All Time],",
                  "        DIVIDE ( ( [Gross Charges 90 Days] + [Estimated Charges A/R 90 Days] ), 90, 0 ),",
                  "        0",
                  "    ),",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"GPAT\", [Gross Patient Service A/R All Time],",
                  "            \"GC9D\", [Gross Charges 90 Days],",
                  "            \"ECA90days\", [Estimated Charges A/R 90 Days]",
                  "        ),",
                  "        AND ( [GPAT] <> BLANK (), AND ( [GC9D] <> BLANK (), [ECA90days] <> BLANK () ) )",
                  "    )",
                  ")"
                ],
                "isHidden": true
              },
              {
                "name": "Net DSO1",
                "expression": [
                  "CALCULATE (",
                  "    DIVIDE (",
                  "        [Net Patient Service A/R All Time],",
                  "        DIVIDE ( [Net Patient Service Revenue 90 Days], 90, 0 ),",
                  "        BLANK ()",
                  "    ),",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"A\", [Net Patient Service A/R All Time],",
                  "            \"B\", [Net Patient Service Revenue 90 Days]",
                  "        ),",
                  "        AND ( [A] <> BLANK (), [B] <> BLANK () )",
                  "    )",
                  ")"
                ],
                "isHidden": true
              },
              {
                "name": "Total Cases  ALE/Cases Denom",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"TotalCases\", [Total Cases],",
                  "            \"GLAmount\", [GL Amount]",
                  "        ),",
                  "        AND ( [TotalCases] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [Total Cases]",
                  ")"
                ],
                "formatString": "0",
                "isHidden": true
              },
              {
                "name": "GL Amount  ALE/Cases Numer",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"TotalCases\", [Total Cases],",
                  "            \"GLAmount\", [GL Amount]",
                  "        ),",
                  "        AND ( [TotalCases] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [GL Amount]",
                  ")"
                ],
                "formatString": "#,0.00",
                "isHidden": true
              },
              {
                "name": "Total Minutes for ALE/Min Denom",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"TotalMins\", [Total Minutes],",
                  "            \"GLAmount\", [GL Amount]",
                  "        ),",
                  "        AND ( [TotalMins] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [Total Minutes]",
                  ")"
                ],
                "formatString": "0",
                "isHidden": true
              },
              {
                "name": "Total GL Amount for ALE/Min Numer",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                'ZZ Lawson GL Actuals',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit]",
                  "            ),",
                  "            \"TotalMins\", [Total Minutes],",
                  "            \"GLAmount\", [GL Amount]",
                  "        ),",
                  "        AND ( [TotalMins] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [GL Amount]",
                  ")"
                ],
                "formatString": "#,0.00",
                "isHidden": true
              }
            ],
            "annotations": [
              {
