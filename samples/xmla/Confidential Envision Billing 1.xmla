            ],
            "partitions": [
              {
                "name": "_Oracle Labor Tracker",
                "dataView": "full",
                "source": {
                  "type": "query",
                  "query": [
                    "SELECT",
                    "\t  ",
                    "d_account_unit_sk",
                    "\t,d_gl_account_sk",
                    "\t,kronos_adjusted_apply_date",
                    "\t,kronos_tot_hrs",
                    "\t,kronos_hourly_pay_rate",
                    "\t,oracle_hourly_pay_rate",
                    "\t,kronos_total_wages",
                    "\t,kronos_flat_amt",
                    "\t,labor_cost",
                    "\t,prorated_budget",
                    "\t,year_max_budget",
                    "\t,budget",
                    "\t,replace(day_date,'-','')\t\t\"service_d_date_sk\"",
                    "\t,hyp_gl_account_alias\t\t\"Hyp GL Descr\"",
                    "\t,hyp_gl_account_parent\t\t\"Hyp GL Parent\"",
                    "\t,is_complete_entry_facility\t\t\"Is Complete Entry Facility\"",
                    "\t,prorated_labor_cost",
                    "",
                    "FROM EDW_INT.dbo.vf_labor_tracker_oracle",
                    "WHERE dashbord_filter = 'SUMMARY' ;"
                  ],
                  "dataSource": "EDW_INT"
                }
              }
            ],
            "measures": [
              {
                "name": "Oracle Budget",
                "expression": "SUM([prorated_budget])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Oracle Labor Tracker",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Oracle Labor Cost",
                "expression": "SUM([labor_cost])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Oracle Labor Tracker",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Kronos Total Hrs",
                "expression": "SUM([kronos_tot_hrs])",
                "displayFolder": "Oracle Labor Tracker"
              },
              {
                "name": "Prorated Labor Cost",
                "expression": "SUM([prorated_labor_cost])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Oracle Labor Tracker",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Prorated Labor Cost Cummlative",
                "expression": [
                  " IF(MAX('Date Of Service'[Serv Dte])<TODAY(),",
                  "CALCULATE (",
                  "    [Prorated Labor Cost],",
                  "    FILTER (",
                  "        ALLSELECTED ( 'Date Of Service' ),",
                  "                   'Date Of Service'[Serv Dte] <=MAX( 'Date Of Service'[Serv Dte])",
                  "    )",
                  "),BLANK())"
                ],
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Oracle Labor Tracker",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              }
            ],
