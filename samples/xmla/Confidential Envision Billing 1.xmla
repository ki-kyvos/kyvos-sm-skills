                "dataType": "string",
                "sourceColumn": "gl_account_descr",
                "displayFolder": "Labor Cost Budget"
              },
              {
                "name": "labor_cost",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "labor_cost"
              },
              {
                "name": "budget",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "budget"
              },
              {
                "name": "prorated_budget",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "prorated_budget"
              },
              {
                "name": "month_max_budget",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "month_max_budget"
              },
              {
                "name": "ytd_budget",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "ytd_budget"
              },
              {
                "type": "calculated",
                "name": "Labor Cost Yr Mnth",
                "dataType": "string",
                "isDataTypeInferred": true,
                "expression": "CONCATENATE([Labor Cost yr],CONCATENATE(\" \",[Labor Cost Mnth]))",
                "displayFolder": "Labor Cost Budget"
              }
            ],
            "partitions": [
              {
                "name": "_Labor Cost Budget",
                "dataView": "full",
                "source": {
                  "type": "query",
                  "query": [
                    "SELECT",
                    "  \tevent_d_date_sk",
                    "\t,d_account_unit_sk",
                    "\t,d_gl_account_sk",
                    "\t,year_num",
                    "\t,month_name",
                    "\t,acct_unit_descr",
                    "\t,gl_account_descr",
                    "\t,labor_cost",
                    "\t,budget",
                    "\t,prorated_budget",
                    "\t,month_max_budget",
                    "\t,ytd_budget",
                    " FROM EDW_INT.dbo.vf_labor_cost_budget ;"
                  ],
                  "dataSource": "EDW_INT"
                }
              }
            ],
            "measures": [
              {
                "name": "Labor Cost",
                "expression": "SUM([labor_cost])",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Cost",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Labor Cost Budget",
                "expression": "MAX([budget])",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Budget",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Labor Cost Prorated Budget",
                "expression": "SUM([prorated_budget])",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Budget",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Month Max Budget",
                "expression": "SUM([month_max_budget])",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Budget",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Prorated Budget",
                "expression": "SUM([ytd_budget])",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Budget",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "YTD Budget",
                "expression": [
                  "CALCULATE (",
                  "    [Prorated Budget], ",
                  "    FILTER (",
                  "        ALL ( 'Date of Service' ), ",
                  "        'Date of Service'[Serv Yr] = MAX ( 'Date of Service'[Serv Yr] )",
                  "            && 'Date of Service'[Serv Dte] <= MAX ( 'Date of Service'[Serv Dte] )",
                  "    )",
                  ")"
                ],
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Budget",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "YTD Labor Cost",
                "expression": [
                  "CALCULATE (",
                  "    [Labor Cost], ",
                  "    FILTER (",
                  "        ALL ( 'Date of Service' ), ",
                  "        'Date of Service'[Serv Yr] = MAX ( 'Date of Service'[Serv Yr] )",
                  "            && 'Date of Service'[Serv Dte] <= MAX ( 'Date of Service'[Serv Dte] )",
                  "    )",
                  ")"
                ],
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Labor Cost Budget",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              }
            ],
            "annotations": [
              {
                "name": "_TM_ExtProp_DbTableName",
                "value": "_Labor Cost Budget"
              },
              {
                "name": "_TM_ExtProp_QueryDefinition",
                "value": [
                  "SELECT [event_d_date_sk]",
                  "      ,[d_account_unit_sk]",
                  "      ,[d_gl_account_sk]",
                  "      ,[year_num]",
                  "      ,[month_name]",
                  "      ,[acct_unit_descr]",
                  "      ,[gl_account_descr]",
                  "      ,[labor_cost]",
                  "      ,[budget]",
                  "      ,[prorated_budget]",
