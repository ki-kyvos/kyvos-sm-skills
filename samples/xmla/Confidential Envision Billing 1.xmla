          {
            "name": "_ADAL",
            "columns": [
              {
                "name": "d_facility_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "d_facility_sk"
              },
              {
                "name": "service_d_date_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "service_d_date_sk"
              },
              {
                "name": "d_patient_type_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "d_patient_type_sk"
              },
              {
                "name": "bucket",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "bucket"
              },
              {
                "name": "cnt",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "cnt"
              },
              {
                "name": "Billing System",
                "dataType": "string",
                "sourceColumn": "Billing System",
                "displayFolder": "ADAL"
              },
              {
                "name": "d_time_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "d_time_sk"
              },
              {
                "name": "Time Interval Flag",
                "dataType": "string",
                "sourceColumn": "time_interval_flag"
              },
              {
                "name": "Is OB",
                "dataType": "string",
                "sourceColumn": "Is OB",
                "displayFolder": "ADAL"
              },
              {
                "name": "Sites Of Service",
                "dataType": "int64",
                "sourceColumn": "Sites Of Service",
                "displayFolder": "ADAL"
              }
            ],
            "partitions": [
              {
                "name": "_ADAL",
                "dataView": "full",
                "source": {
                  "type": "query",
                  "query": [
                    "SELECT\ta.d_facility_sk",
                    "\t,a.service_d_date_sk",
                    "\t,a.d_patient_type_sk",
                    " \t,a.bucket",
                    " \t,a.time_interval_flag",
                    "\t,a.cnt",
                    "\t,d_time_sk",
                    "\t,billing_system AS \"Billing System\"\t,procedure_type AS \"Is OB\"",
                    "\t,sites_of_service AS \"Sites Of Service\"",
                    " FROM",
                    "\tEDW_INT.dbo.vf_adal a"
                  ],
                  "dataSource": "EDW_INT"
                }
              }
            ],
            "measures": [
              {
                "name": "Fact Days Cnt",
                "expression": "DISTINCTCOUNT([service_d_date_sk] )",
                "isHidden": true
              },
              {
                "name": "Case Avg",
                "expression": "DIVIDE([ADAL Case Cnt], [Fact Days Cnt],0)",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              },
              {
                "name": "PALDaily",
                "expression": [
                  "SUMX (",
                  "    VALUES ( 'Date Of Service'[Serv Dte] ),",
                  "    RANKX ('Time', CALCULATE([ADAL Case Cnt]), 1, 0, DENSE )",
                  ")"
                ],
                "displayFolder": "ADAL"
              },
              {
                "name": "PAL",
                "expression": [
                  "SUMX( ",
                  "    SUMMARIZE (",
                  "        '_ADAL',",
                  "        '_ADAL'[service_d_date_sk],",
                  "        '_ADAL'[d_facility_sk],",
                  "        \"AVGDaily\", MAX ( '_ADAL'[cnt] )",
                  "    ),",
                  "    [AVGDaily]",
                  ")"
                ],
                "displayFolder": "ADAL"
              },
              {
                "name": "Cases/PAL",
                "expression": "DIVIDE([Total Cases],[PALDaily],BLANK())",
                "displayFolder": "ADAL"
              },
              {
                "name": "Minutes/PAL",
                "expression": "DIVIDE([Total Minutes],[PALDaily],BLANK())",
                "displayFolder": "ADAL"
              },
              {
                "name": "Units/PAL",
                "expression": "DIVIDE([Total Units],[PALDaily],BLANK())",
                "displayFolder": "ADAL"
              },
              {
                "name": "Units/PAL - Norm",
                "expression": "DIVIDE([Total Units - Norm],[PALDaily],BLANK())",
                "displayFolder": "ADAL"
              },
              {
                "name": "Case StdDev",
                "expression": "STDEV.P ( _ADAL[cnt] )",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              },
              {
                "name": "Case Avg +1 StdDev",
                "expression": "[Case Avg] + [Case StdDev]",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              },
              {
                "name": "Case Avg +2 StdDev",
                "expression": "[Case Avg] + ([Case StdDev]*2)",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              },
              {
                "name": "ADAL Case Cnt",
                "expression": "SUM([cnt])",
                "displayFolder": "ADAL"
              },
              {
                "name": "Case Avg -2 StdDev",
                "expression": "IF([Case Avg] - ([Case StdDev]*2) <0,0,[Case Avg] - ([Case StdDev]*2))",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              },
              {
                "name": "Case Min",
                "expression": [
                  "MINX (",
                  "    ADDCOLUMNS (",
                  "        SUMMARIZE (",
                  "            _adal,",
                  "            _adal[service_d_date_sk]",
                  "        ),",
                  "        \"MinDaily\", CALCULATE([ADAL Case Cnt] )",
                  "    ),",
                  "    [MinDaily]",
                  ")"
                ],
                "displayFolder": "ADAL"
              },
              {
                "name": "ADAL Days Cnt",
                "expression": "DISTINCTCOUNT( _ADAL[service_d_date_sk] )",
                "displayFolder": "ADAL"
              },
              {
                "name": "Case Max",
                "expression": [
                  "MAXX (",
                  "    ADDCOLUMNS (",
                  "        SUMMARIZE (",
                  "            _ADAL,",
                  "\t_ADAL[service_d_date_sk]",
                  "        ),",
                  "        \"MaxDaily\", CALCULATE([ADAL Case Cnt] )",
                  "    ),",
                  "    [MaxDaily]",
                  ")"
                ],
                "displayFolder": "ADAL"
              },
              {
                "name": "Case Avg -1 StdDev",
                "expression": "IF([Case Avg] - [Case StdDev]<0,0,[Case Avg] - ([Case StdDev]))",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              },
              {
                "name": "PeakDailyPAL",
                "expression": "SUMX ( VALUES ( 'Date Of Service'[Serv Dte] ),  RANKX ('Time',   [ADAL Case Cnt],1,0,DENSE) )",
                "displayFolder": "ADAL"
              },
              {
                "name": "RANKOfCnts",
                "expression": "RANKX ('Time',   CALCULATE(SUM([Cnt])),1,0,DENSE)",
                "displayFolder": "ADAL"
              },
              {
                "name": "PAL Capacity",
                "expression": "DIVIDE([Case Avg_Ver2], [PALDaily_Ver2],0)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "isHidden": true
              },
              {
                "name": "PALDaily_Ver2",
                "expression": "CALCULATE([PALDaily], ALL('Time'), ALLSELECTED('Date Of Service'))",
                "isHidden": true
              },
              {
                "name": "Case Avg_Ver2",
                "expression": "IF(COUNTROWS('Time')>1,DIVIDE([ADAL Case Cnt], COUNTROWS('Time'),0), [Case Avg])",
                "formatString": "#,0.00",
                "isHidden": true
              },
              {
                "name": "Case StdDev by Fac",
                "expression": " IF(HASONEVALUE(Facility[Fac Name]),[Case StdDev], SUMX(VALUES(Facility[Fac Name]),[Case StdDev]))",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              },
              {
                "name": "Case Avg +1 StdDev by Fac",
                "expression": "[Case Avg] + [Case StdDev by Fac]",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              },
              {
                "name": "Case Avg +2 StdDev by Fac",
                "expression": "[Case Avg] + ([Case StdDev by Fac]*2)",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              },
              {
                "name": "Case Avg -1 StdDev by Fac",
                "expression": "IF([Case Avg] - [Case StdDev by Fac]<0,0,[Case Avg] - ([Case StdDev by Fac]))",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              },
              {
                "name": "Case Avg -2 StdDev by Fac",
                "expression": "IF([Case Avg] - ([Case StdDev by Fac]*2) <0,0,[Case Avg] - ([Case StdDev by Fac]*2))",
                "formatString": "#,0.00",
                "displayFolder": "ADAL"
              }
            ],
            "annotations": [
              {
                "name": "_TM_ExtProp_DbTableName",
                "value": "_ADAL"
              },
              {
                "name": "_TM_ExtProp_QueryDefinition",
                "value": [
                  "SELECT",
                  "\ta.d_facility_sk",
                  "\t,a.service_d_date_sk",
                  "\t,a.d_patient_type_sk",
                  " \t,a.bucket",
                  " \t,a.time_interval_flag",
                  "\t,a.cnt",
                  "\t,d_time_sk",
                  "\t,billing_system AS [Billing System]",
                  "\t,procedure_type AS [Is OB]",
                  "FROM",
                  "\tEDW_INT.dbo.vf_adal a"
                ]
              },
              {
                "name": "QueryEditorSerialization",
                "value": [
                  "<?xml version=\"1.0\" encoding=\"UTF-16\"?><Gemini xmlns=\"QueryEditorSerialization\"><AnnotationContent><![CDATA[<RSQueryCommandText>SELECT",
                  "\ta.d_facility_sk",
                  "\t,a.service_d_date_sk",
                  "\t,a.d_patient_type_sk",
                  " \t,a.bucket",
                  " \t,a.time_interval_flag",
                  "\t,a.cnt",
                  "\t,d_time_sk",
                  "\t,billing_system AS [Billing System]",
                  "\t,procedure_type AS [Is OB]",
                  "FROM",
                  "\tEDW_INT.dbo.vf_adal a</RSQueryCommandText><RSQueryCommandType>Text</RSQueryCommandType><RSQueryDesignState></RSQueryDesignState>]]></AnnotationContent></Gemini>"
                ]
              }
            ]
          },
