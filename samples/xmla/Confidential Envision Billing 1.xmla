                  "time_dashboard_bucket As [Time Bucket],",
                  "time_dashboard_bucket As [Start Time Bucket],",
                  "hour_type [Hour Type],",
                  "time_bucket_sort,",
                  "CASE WHEN time_sk <>-1 THEN CONVERT(datetime,time_12_short)  END AS s_time",
                  "FROM dbo.vd_time WITH (NOLOCK)"
