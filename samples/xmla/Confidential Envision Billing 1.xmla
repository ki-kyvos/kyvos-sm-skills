                }
              }
            ],
            "measures": [
              {
                "name": "Oracle GL Daily DB Units",
                "expression": "SUM([db_units])",
                "formatString": "0",
                "isHidden": true,
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Gross Charges",
                "expression": "-CALCULATE([Oracle GL Daily Amt],'Oracle Hyp Account'[Hyp Oracle Parent]=\"Gross Charges\")+[Gross Charges]",
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Gross Patient Service A/R",
                "expression": "CALCULATE([Oracle GL Daily Amt],'Oracle Hyp Account'[Hyp Oracle Parent]=\"Gross Patient Service AR\")+[Gross Patient Service A/R]",
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Est Charges A/R",
                "expression": "-CALCULATE([Oracle GL Daily Amt],'Oracle Hyp Account'[Hyp Oracle Parent]=\"Estimated Charges\")+[Estimated Charges A/R]",
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Gross Charges 90 Days",
                "expression": "CALCULATE([Oracle Gross Charges],DATESBETWEEN('Date Of Service'[Serv Dte],FIRSTDATE(DATEADD('Date Of Service'[Serv Dte],-2,MONTH)), MAX('Date Of Service'[Serv Dte])))",
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Gross Patient Service A/R All Time",
                "expression": "CALCULATE([Oracle Gross Patient Service A/R],FILTER(ALL('Date Of Service'),'Date Of Service'[Serv Dte]<=MAX('Date Of Service'[Serv Dte])))",
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Est Charges A/R 90 Days",
                "expression": "CALCULATE([Oracle Est Charges A/R],DATESBETWEEN('Date Of Service'[Serv Dte],FIRSTDATE(DATEADD('Date Of Service'[Serv Dte],-2,MONTH)), MAX('Date Of Service'[Serv Dte])))",
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Gross DSO",
                "expression": "DIVIDE([Oracle Gross Patient Service A/R All Time],DIVIDE(([Oracle Gross Charges 90 Days]+[Oracle Est Charges A/R 90 Days]),90,0),0)",
                "formatString": "#,0.00",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle GL Daily CR Units",
                "expression": "SUM([cr_units])",
                "formatString": "0",
                "isHidden": true,
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle GL Daily Amt",
                "expression": "[Oracle GL Daily DB Units]-[Oracle GL Daily CR Units]",
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Net Patient Service AR",
                "expression": " CALCULATE([Oracle GL Daily Amt], 'Oracle Hyp Account'[Level 6]=\"AR - Net Patient Service\")+[Net Patient Service A/R]",
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Net Patient Service Revenue",
                "expression": "-(-[Oracle Gross Charges]-[Oracle Est Charges A/R]-[Oracle Total Allowances]+[Net Patient Service Revenue])",
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Net Patient Service Revenue 90 Days",
                "expression": [
                  "CALCULATE (",
                  "    [Oracle Net Patient Service Revenue],",
                  "    DATESBETWEEN (",
                  "        'Date Of Service'[Serv Dte],",
                  "        FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -2, MONTH ) ),",
                  "        MAX ( 'Date Of Service'[Serv Dte] )",
                  "    )",
                  ")"
                ],
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Net Patient Service A/R All Time",
                "expression": [
                  "CALCULATE (",
                  "    [Oracle Net Patient Service AR],",
                  "    FILTER (",
                  "        ALL ( 'Date Of Service' ),",
                  "        'Date Of Service'[Serv Dte] <= MAX ( 'Date Of Service'[Serv Dte] )",
                  "    )",
                  ")"
                ],
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Net DSO",
                "expression": "DIVIDE([Oracle Net Patient Service A/R All Time],DIVIDE([Oracle Net Patient Service Revenue 90 Days],90,0),BLANK())",
                "formatString": "#,0.00",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Total Allowances",
                "expression": "-CALCULATE([Oracle GL Daily Amt],'Oracle Hyp Account'[Hyp Oracle Parent]=\"Total Allowances\")",
                "formatString": "0",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle GL Amount for ALE Numer",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                '_Oracle GL Daily',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Oracle Profit Center],'GL Account'[Is ALE]",
                  "            ),",
                  "            \"TotalUnits - Nm\", [Total Units - Norm],",
                  "            \"GLAmount\", [Oracle GL Daily Amt]",
                  "        ),",
                  "        AND ( [TotalUnits - Nm] <> BLANK (), AND([GLAmount] <> BLANK (), 'GL Account'[Is ALE]=TRUE() ))",
                  "    ),",
                  "    [GLAmount]",
                  ")"
                ],
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Total Units - Norm for ALE Denom",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                '_Oracle GL Daily',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Oracle Profit Center]",
                  "            ),",
                  "            \"TotalUnits - Nm\", [Total Units - Norm],",
                  "            \"GLAmount\", [Oracle GL Amount for ALE Numer]",
                  "        ),",
                  "        AND ( [TotalUnits - Nm] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [Total Units - Norm]",
                  ")"
                ],
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Total Minutes for ALE/Min Denom",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "               '_Oracle GL Daily',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Oracle Profit Center]",
                  "            ),",
                  "            \"TotalMins\", [Total Minutes],",
                  "            \"GLAmount\", [Oracle GL Daily Amt]",
                  "        ),",
                  "        AND ( [TotalMins] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [Total Minutes]",
                  ")"
                ],
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Total Units for ALE Denom",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                '_Oracle GL Daily',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Oracle Profit Center]",
                  "            ),",
                  "            \"TotalUnits\", [Total Units],",
                  "            \"GLAmount\", [Oracle GL Daily Amt]",
                  "        ),",
                  "        AND ( [TotalUnits] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [Total Units]",
                  ")"
                ],
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Total Cases  ALE/Cases Denom",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                '_Oracle GL Daily',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Oracle Profit Center]",
                  "            ),",
                  "            \"TotalCases\", [Total Cases],",
                  "            \"GLAmount\", [Oracle GL Daily Amt]",
                  "        ),",
                  "        AND ( [TotalCases] <> BLANK (), [GLAmount] <> BLANK () )",
                  "    ),",
                  "    [Total Cases]",
                  ")"
                ],
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle ALE/Units - Norm",
                "expression": "CALCULATE(DIVIDE([Oracle GL Amount for ALE Numer],[Oracle Total Units - Norm for ALE Denom],0),'GL Account'[Is ALE]= TRUE)",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Oracle GL Daily",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Oracle ALE/Minutes",
                "expression": "DIVIDE([Oracle GL Amount for ALE Numer], [Oracle Total Minutes for ALE/Min Denom],BLANK())",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Oracle GL Daily",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Oracle ALE/Units",
                "expression": "CALCULATE(DIVIDE([Oracle GL Amount for ALE Numer],[Oracle Total Units for ALE Denom],0),'GL Account'[Is ALE]= TRUE)",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Oracle GL Daily",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Oracle ALE/Cases",
                "expression": "CALCULATE(DIVIDE([Oracle GL Amount for ALE Numer],[Oracle Total Cases  ALE/Cases Denom],0),'GL Account'[Is ALE]= TRUE)",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Oracle GL Daily",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Oracle Budgeted ALE / Case",
                "expression": "DIVIDE( CALCULATE([Oracle GL Daily Amt], 'GL Account'[Is ALE] = True ), [Hyp Budget Cases] , BLANK())",
                "formatString": "#,0.00",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Gross Margin",
                "expression": "-CALCULATE([Oracle GL Daily Amt], 'Oracle Hyp Account'[Level 3]=\"Gross Margin\")",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle Net Revenue",
                "expression": "-CALCULATE([Oracle GL Daily Amt], 'Oracle Hyp Account'[Level 4]=\"net revenue\")",
                "displayFolder": "Oracle GL Daily"
              },
              {
                "name": "Oracle PnC Exp",
                "expression": "CALCULATE([Oracle GL Daily Amt], 'Oracle Hyp Account'[Level 4]=\"Personnel and Controllable Expenses\")",
                "displayFolder": "Oracle GL Daily"
              }
            ],
