              {
                "name": "Pending Estimated Net Revenue",
                "expression": "[Pending Charge] * '_Net Revenue'[Predicted Rev]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Flash Report",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Estimated Net Revenue",
                "expression": "[Pending Estimated Net Revenue] + '_Net Revenue'[Predicted Rev]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Flash Report",
                "annotations": [
