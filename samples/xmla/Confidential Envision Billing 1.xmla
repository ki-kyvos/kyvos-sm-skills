            ],
            "measures": [
              {
                "name": "Kronos Time Hrs",
                "expression": "DIVIDE(SUM([time_in_seconds]),3600)",
                "formatString": "#,0.00",
                "isHidden": true
              },
              {
                "name": "Worked Hrs",
                "expression": "DIVIDE(SUM([worked_time_in_seconds]),3600, 0)",
                "formatString": "#,0.00",
                "isHidden": true
              },
              {
                "name": "Employee Cnt",
                "expression": "DISTINCTCOUNT([d_employee_sk])",
                "formatString": "#,0",
                "isHidden": true
              },
              {
                "name": "Event Days Cnt",
                "expression": "DISTINCTCOUNT([event_d_date_sk])",
                "formatString": "#,0",
                "isHidden": true
              },
              {
                "name": "TimeHrs/Prov/Day",
                "expression": "IFERROR([Time Hrs]/[Employee Cnt]/[Event Days Cnt],BLANK())",
                "formatString": "#,0.00",
                "isHidden": true
              },
              {
                "name": "Total Time Hrs",
                "expression": "DIVIDE(SUM([tot_time_in_seconds]),3600, 0)",
                "formatString": "#,0.00",
                "displayFolder": "Kronos"
              },
              {
                "name": "Worked Hrs All Facilities",
                "expression": "CALCULATE([Worked Hrs], ALLExcept(Facility, Facility[Fac LOB]))",
                "isHidden": true
              },
              {
                "name": "Total Time Hrs All Facilities",
                "expression": "CALCULATE([Total Time Hrs], ALLExcept(Facility, Facility[Fac LOB]))",
                "isHidden": true
              },
              {
                "name": "Worked Hrs All Providers",
                "expression": "CALCULATE([Worked Hrs], ALL(Provider))",
                "isHidden": true
              },
              {
                "name": "Total Time Hrs All Providers",
                "expression": "CALCULATE([Total Time Hrs], ALL(Provider))",
                "isHidden": true
              },
              {
                "name": "Worked Hrs All Facilities All Providers",
                "expression": "CALCULATE([Worked Hrs], ALL(Provider), All(Facility))",
                "isHidden": true
              }
            ],
