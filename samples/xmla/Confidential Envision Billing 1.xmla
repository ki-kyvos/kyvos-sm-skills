                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "ChargesLast3Months_Norm_ServDte",
                "expression": [
                  "IF (",
                  "    CALCULATE (",
                  "        [Gross Charge - Norm],",
                  "        FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -3, MONTH ) )",
                  "    )",
                  "        = 0",
                  "        || CALCULATE (",
                  "            [Gross Charge - Norm],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -2, MONTH ) )",
                  "        )",
                  "            = 0",
                  "        || CALCULATE (",
                  "            [Gross Charge - Norm],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -1, MONTH ) )",
                  "        )",
                  "            = 0,",
                  "    BLANK (),",
                  "    CALCULATE (",
                  "        [Gross Charge - Norm],",
                  "        DATESBETWEEN (",
                  "            'Date Of Service'[Serv Dte],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -3, MONTH ) ),",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -1, MONTH ) )",
                  "        )",
                  "    )",
                  ")"
                ],
                "isHidden": true
              },
              {
                "name": "Trailing 3 Serv Mnth Chg Avg - Norm",
                "expression": "DIVIDE([ChargesLast3Months_Norm_ServDte],3,BLANK())",
                "displayFolder": "Financial\\Charges\\Statistics"
              },
              {
                "name": "Pat Bad Debt Writeoff % Trailing 6 Mnth Chg - Norm Avg",
                "expression": "DIVIDE(-[Pat Bad Debt Writeoff], [Trailing 6 Mnth Chg Avg - Norm], BLANK())",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              },
