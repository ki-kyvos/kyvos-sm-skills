            "measures": [
              {
                "name": "FH Fiftieth Percentile Charge Impact",
                "description": "FairHealth Anesthesia measures",
                "expression": "CALCULATE([Gross Charge / Proc] - FIRSTNONBLANK('Fair Health Rate'[FH Fifty Percentile],1)) * [Proc Cnt]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "FH Mean Charge Impact",
                "description": "FairHealth Anesthesia measures",
                "expression": "CALCULATE([Gross Charge / Proc] - FIRSTNONBLANK('Fair Health Rate'[FH Inpatient Mean],1)) * [Proc Cnt]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "annotations": [
                  {
