                "displayFolder": "Billing"
              },
              {
                "type": "calculated",
                "name": "Patient Age",
                "dataType": "double",
                "isDataTypeInferred": true,
                "expression": [
                  "",
                  "VAR Birthdate = RELATED('Patient'[Pat Birth Dte])",
                  "RETURN",
                  "    IF (",
                  "        NOT ISBLANK ( Birthdate ),",
                  "        VAR ThisDay = TODAY()",
                  "        VAR IntBirthdate = YEAR ( Birthdate ) * 10000 + MONTH ( Birthdate ) * 100 + DAY ( Birthdate )",
                  "        VAR IntThisDay = YEAR ( ThisDay ) * 10000 + MONTH ( ThisDay ) * 100 + DAY ( ThisDay )",
                  "        VAR Age = QUOTIENT ( IntThisDay - IntBirthdate, 10000 )",
                  "        VAR CheckedAge = DIVIDE ( Age, NOT ISBLANK ( Birthdate ) )",
                  "        RETURN",
                  "            CheckedAge",
                  "    )"
                ],
                "displayFolder": "Billing"
              },
              {
                "type": "calculated",
                "name": "Is Age 18 Status",
                "dataType": "string",
                "expression": [
                  "",
                  "IFERROR (",
                  "\tIF([Patient Age at Serv Dte] < 18,",
                  "\t\t\"< 18 years\",",
                  "\t\t\">= 18 years\"",
                  "\t )",
                  "    ,BLANK()",
                  ")"
                ],
                "displayFolder": "Billing"
              },
              {
                "type": "calculated",
                "name": "Patient Age at Serv Dte",
                "dataType": "double",
                "isDataTypeInferred": true,
                "expression": [
                  "",
                  "VAR Birthdate = RELATED('Patient'[Pat Birth Dte])",
                  "RETURN",
                  "    IF (",
                  "        NOT ISBLANK ( Birthdate ),",
                  "        VAR ThisDay = RELATED('Date Of Service'[Serv Dte])",
                  "        VAR IntBirthdate = YEAR ( Birthdate ) * 10000 + MONTH ( Birthdate ) * 100 + DAY ( Birthdate )",
                  "        VAR IntThisDay = YEAR ( ThisDay ) * 10000 + MONTH ( ThisDay ) * 100 + DAY ( ThisDay )",
                  "        VAR Age = QUOTIENT ( IntThisDay - IntBirthdate, 10000 )",
                  "        VAR CheckedAge = DIVIDE ( Age, NOT ISBLANK ( Birthdate ) )",
                  "        RETURN",
                  "            CheckedAge",
                  "    )"
                ],
                "displayFolder": "Billing"
              },
              {
                "name": "ancillary_d_provider_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "ancillary_d_provider_sk",
                "displayFolder": "Billing"
