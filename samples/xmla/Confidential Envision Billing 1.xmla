                  ],
                  "dataSource": "EDW_INT"
                }
              }
            ],
            "measures": [
              {
                "name": "Oracle GL Monthly YTD Amount",
                "expression": "SUM([ytd_amount])",
                "formatString": "#,0.00",
                "isHidden": true,
                "displayFolder": "Production Tracker"
              },
              {
                "name": "Oracle Period Net",
                "expression": "SUM([period_net])",
                "formatString": "0",
                "isHidden": true,
                "displayFolder": "Oracle GL Monthly"
              },
              {
                "name": "Oracle GL Amount for ALE Numer1",
                "expression": [
                  "SUMX (",
                  "    FILTER (",
                  "        ADDCOLUMNS (",
                  "            SUMMARIZE (",
                  "                '_Oracle GL Daily',",
                  "                'Date Of Service'[Serv Yr],",
                  "                'Date Of Service'[yr_mnth_order],",
                  "                'Accounting Unit'[Company-Acctg Unit],'GL Account'[Is ALE]",
                  "            ),",
                  "            \"TotalUnits - Nm\", [Total Units - Norm],",
                  "            \"GLAmount\", [Oracle GL Daily Amt]",
                  "        ),",
                  "        AND ( [TotalUnits - Nm] <> BLANK (), AND([GLAmount] <> BLANK (), 'GL Account'[Is ALE]=TRUE() ))",
                  "    ),",
                  "    [GLAmount]",
                  ")"
                ],
                "isHidden": true
              }
            ],
            "annotations": [
              {
                "name": "_TM_ExtProp_QueryDefinition",
                "value": [
                  "SELECT ",
                  "       [d_account_unit_sk]",
                  "      ,[d_gl_account_sk]",
                  "      ,[fiscal_month_d_date_sk]",
                  "      ,[d_hyp_entity_hier]\tAS [OGLM Hyp Entity Hier]",
                  "      ,[d_hyp_department_hier]\tAS [OGLM Hyp Department Hier]",
                  "      ,[d_hyp_profit_center_hier]\tAS [OGLM Hyp Profit Center Hier]",
                  "      ,[d_hyp_account_hier]",
                  "      ,[ytd_amount]",
                  "      ,[period_net]\t",
                  "  FROM ",
                  "\tEDW_INT.[dbo].[vf_oracle_gl_month]  WITH (NOLOCK)"
                ]
