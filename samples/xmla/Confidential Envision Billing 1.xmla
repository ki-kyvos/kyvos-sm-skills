            ],
            "measures": [
              {
                "name": "FH 95th Percentile Anesthesia Allowable Impact",
                "expression": " CALCULATE(DIVIDE([Proxy 1], [Total Units],0) - FIRSTNONBLANK('Fair Health Anes Allowable Rate'[FH Ninety Five Percentile Amt Anes Allowable],1)) * [Total Units]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "FH Fiftieth Percentile Anesthesia Allowable Impact",
                "expression": "CALCULATE(DIVIDE([Proxy 1], [Total Units],0) - FIRSTNONBLANK('Fair Health Anes Allowable Rate'[FH Fifty Percentile Amt Anes Allowable],1)) * [Total Units]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
