              {
                "name": "Encounter with Denials",
                "expression": "CALCULATE([Encounter Cnt], 'Encounter'[Has Denials]=TRUE())",
                "displayFolder": "Billing"
              },
              {
                "name": "Encounter Denials %",
                "expression": "DIVIDE([Encounter with Denials],[Encounter Cnt],0)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "Encounters Actionable Cnt",
                "expression": "CALCULATE([Encounter with Denials], 'Denial Code'[Is Actionable]=TRUE())",
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "Encounters Actionable Denials %",
                "expression": "DIVIDE([Encounters Actionable Cnt],[Encounter Cnt],0)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "Length of Stay Median",
                "expression": "CALCULATE(MEDIAN([length_of_stay]), _Billing[length_of_stay]>0)",
                "displayFolder": "Billing"
              },
              {
                "name": "Adj Excl Bad Debt",
                "expression": "[Total Adjustment]-[Bad Debt Writeoff]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Adjustments\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Closed Claim Bad Debt %",
                "expression": [
                  "CALCULATE (",
                  "    DIVIDE ( - [Bad Debt Writeoff], [Gross Charge], 0 ),",
                  "    FILTER (",
                  "        'Account Balance Class',",
                  "        OR (",
                  "            [Account Balance Class] = \"Zero Balance Zero Paid\",",
                  "            [Account Balance Class] = \"Zero Balance\"",
                  "        )",
                  "    )",
                  ")"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Statistics"
              },
              {
                "name": "Closed Claim Bad Debt",
                "expression": [
                  "",
                  "IF (HASONEVALUE('Account Balance Class'[Account Balance Class])",
                  "    && COUNTROWS ( 'Account Balance Class' ) <> 1,",
                  "    ([Closed Claim Bad Debt %] * [Gross Charge]),",
                  "CALCULATE (",
                  "\tSUMX(VALUES('Account Balance Class'[Account Balance Class]),",
                  "    [Closed Claim Bad Debt %] * [Gross Charge]),",
                  "    FILTER (",
                  "        'Account Balance Class',",
                  "        OR (",
                  "            [Account Balance Class] = \"Zero Balance Zero Paid\",",
                  "            [Account Balance Class] = \"Zero Balance\"",
                  "        )",
                  "    )",
                  "))"
                ],
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Adjustments\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Closed Claim Adj Excl Bad Debt %",
                "expression": [
                  "",
                  "CALCULATE (",
                  "    DIVIDE ( - [Adj Excl Bad Debt], [Gross Charge], 0 ),",
                  "    FILTER (",
                  "        'Account Balance Class',",
                  "        OR (",
                  "            [Account Balance Class] = \"Zero Balance Zero Paid\",",
                  "            [Account Balance Class] = \"Zero Balance\"",
                  "        )",
                  "    )",
                  ")"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Statistics"
              },
              {
                "name": "Closed Claim Adj Excl Bad Debt",
                "expression": [
                  "IF (",
                  "\tHASONEVALUE('Account Balance Class'[Account Balance Class])",
                  "    && COUNTROWS ( 'Account Balance Class' ) <> 1,",
                  "    [Gross Charge] * [Closed Claim Adj Excl Bad Debt %],",
                  "CALCULATE (",
                  "\tSUMX(VALUES('Account Balance Class'[Account Balance Class]),",
                  "    [Gross Charge] * [Closed Claim Adj Excl Bad Debt %]),",
                  "    FILTER (",
                  "        'Account Balance Class',",
                  "        OR (",
                  "            [Account Balance Class] = \"Zero Balance Zero Paid\",",
                  "            [Account Balance Class] = \"Zero Balance\"",
                  "        )",
                  "    )",
                  "))"
                ],
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Adjustments\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Pat Bad Debt Writeoff % Pat Resp",
                "expression": "DIVIDE([Pat Bad Debt Writeoff],[Pat Responsibility],0)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              },
              {
                "name": "Pat Bad Debt Writeoff % Allowable Amt",
                "expression": "DIVIDE([Pat Bad Debt Writeoff],[Allowable Amt],0)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              },
              {
                "name": "Net Pat Payment WriteOff Days Avg",
                "expression": "AVERAGE([net_patient_payment_days_to_bad_debt_writeoff])",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              },
              {
                "name": "Total Hours",
                "expression": "DIVIDE([Total Minutes],60,0)",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Proc End Time Day",
                "expression": [
                  "MAXX( ",
                  "    SUMMARIZE (",
                  "        '_Billing',",
                  "        '_Billing'[service_d_date_sk],",
                  "        \"ET\", MAX ('Time Of Procedure End'[e_time] )",
                  "    ),",
                  "    [ET]",
                  ")"
                ],
                "formatString": "hh:mm AM/PM",
                "displayFolder": "Utilization\\Procedures",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"DateTimeCustom\"><DateTimes><DateTime LCID=\"1033\" Group=\"ShortTime\" FormatString=\"hh:mm tt\" /></DateTimes></Format>"
                  }
                ]
              },
              {
                "name": "Proc Start Time Day",
                "expression": [
                  " MINX( ",
                  "    SUMMARIZE (",
                  "        '_Billing',",
                  "        '_Billing'[service_d_date_sk],",
                  "        \"ST\", MIN ('Time Of Procedure Start'[s_time] )",
                  "    ),",
                  "    [ST]",
                  ")"
                ],
                "formatString": "hh:mm AM/PM",
                "displayFolder": "Utilization\\Procedures",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"DateTimeCustom\"><DateTimes><DateTime LCID=\"1033\" Group=\"ShortTime\" FormatString=\"hh:mm tt\" /></DateTimes></Format>"
                  }
                ]
              },
              {
                "name": "Proc Day Duration",
                "expression": [
                  " IF (",
                  "        DISTINCTCOUNT ( '_Billing'[service_d_date_sk] ) = 1,",
                  "        IF (",
                  "            [Proc Start Time Day] <= [Proc End Time Day],",
                  "            DATEDIFF ( [Proc Start Time Day], [Proc End Time Day], MINUTE ),",
                  "            DATEDIFF ( [Proc Start Time Day], \"1/1/1900 11:59:00 PM\", MINUTE )",
                  "                + DATEDIFF ( \"1/1/1900 12:00:00 AM\", [Proc End Time Day], MINUTE )",
                  "        ),",
                  "        BLANK ()",
                  "    )"
                ],
                "displayFolder": "Utilization\\Procedures"
              },
              {
                "name": "Downcode Lost RVU",
                "expression": "SUM([downcode_lost_rvu])",
                "formatString": "#,0.00",
                "displayFolder": "Billing\\Procedure"
              },
              {
                "name": "Acuity/Case",
                "expression": "SUMX(SUMMARIZE(_Billing, 'Facility'[Fac LOB], \"ACP\", IF('Facility'[Fac LOB]=\"ANES\",[Total Units - Norm], DIVIDE([Wrk RVU],[Total Cases],0))), [ACP])",
                "isHidden": true
              },
              {
                "name": "EM Acuity Proc",
                "expression": [
                  "",
                  "DIVIDE ([EM Acuity Proc Numer],[EM Acuity Proc Denom],0)",
                  "    "
                ],
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "EM Acuity Proc Numer",
                "expression": [
                  "CALCULATE ( [Proc Cnt], _Billing[cpt_code] = \"99281\" ) * 1",
                  "        + CALCULATE ( [Proc Cnt], _Billing[cpt_code] = \"99282\" ) * 2",
                  "        + CALCULATE ( [Proc Cnt], _Billing[cpt_code] = \"99283\" ) * 3",
                  "        + CALCULATE ( [Proc Cnt], _Billing[cpt_code] = \"99284\" ) * 4",
                  "        + CALCULATE ( [Proc Cnt], _Billing[cpt_code] = \"99285\" ) * 5",
                  "        + CALCULATE ( [Proc Cnt], _Billing[cpt_code] = \"99291\" ) * 6"
                ],
                "formatString": "0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "EM Acuity Proc Denom",
                "expression": [
                  " CALCULATE (",
                  "            [Proc Cnt],",
                  "            OR (",
                  "                _Billing[cpt_code] = \"99282\",",
                  "                OR (",
                  "                    _Billing[cpt_code] = \"99283\",",
                  "                    OR (",
                  "                        _Billing[cpt_code] = \"99284\",",
                  "                        OR ( _Billing[cpt_code] = \"99285\",OR( _Billing[cpt_code] = \"99291\", _Billing[cpt_code]=\"99281\" ))",
                  "                    )",
                  "                )",
                  "            )",
                  "        )",
                  "    "
                ],
                "formatString": "0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "acuity_case_calc",
                "expression": " SUMX(SUMMARIZE(_Billing,'Facility'[Fac LOB],\"APC\", IF('Facility'[Fac LOB]=\"ANES\",[Total Units - Norm], [Total RVU])), DIVIDE([APC], [Total Cases],BLANK()))",
                "isHidden": true
              },
              {
                "name": "True Uninsured Exp",
                "expression": "ABS(CALCULATE([Gross Charge], 'Payer Product Primary'[Pri Payer Product Lvl 3]=\"Self Pay\"))",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "True Uninsured Actual",
                "expression": "ABS(CALCULATE([Net Payment], 'Payer Product Primary'[Pri Payer Product Lvl 3]=\"Self Pay\"))",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Self Pay After Ins Act CPV",
                "expression": "ABS(CALCULATE([Net Pat Payment], 'Payer Product Primary'[Pri Payer Product Lvl 4]<>\"Self Pay\"))",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Self Pay After Ins Exp CPV",
                "expression": "ABS(CALCULATE([Pat Responsibility], 'Payer Product Primary'[Pri Payer Product Lvl 4]<>\"Self Pay\"))",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Uninsured Exp CPV",
                "expression": " abs(DIVIDE([True Uninsured Exp],[Total Cases],0))",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Uninsured Act CPV",
                "expression": "ABS(DIVIDE([True Uninsured Actual],[Total Cases],0))",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Uninsured RR %",
                "expression": "abs(DIVIDE([True Uninsured Actual], [True Uninsured Exp],0))",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\MOR"
              },
              {
                "name": "SPAI Act CPV",
                "expression": "DIVIDE([Self Pay After Ins Act CPV],[Total Cases],0)",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "SPAI Exp CPV",
                "expression": "ABS(DIVIDE([Self Pay After Ins Exp CPV],[Total Cases],0))",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "SPAI RR%",
                "expression": "DIVIDE([SPAI Act CPV],[SPAI Exp CPV],0)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\MOR"
              },
              {
                "name": "Bad Debt % to Total Charge",
                "expression": "DIVIDE(ABS([Pat Bad Debt Writeoff]),[Gross Charge],0)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\MOR"
              },
              {
                "name": "Proc Cnt Last 90 Days",
                "expression": "CALCULATE([Proc Cnt], all('Date of Entry'), DATESINPERIOD('Date of Entry'[Entry Dte], LASTDATE('Date of Entry'[Entry Dte]),-90,DAY))",
                "formatString": "#,0",
                "displayFolder": "Billing\\Early Indicators"
              },
              {
                "name": "EM Proc Cnt Last 90 Days",
                "expression": "CALCULATE([Proc Cnt Last 90 Days], 'CPT Code'[Is EM Code]=\"TRUE\")",
                "formatString": "#,0",
                "displayFolder": "Billing\\Early Indicators"
              },
              {
                "name": "EM Proc Cnt Distribution 90 Day",
                "expression": "DIVIDE([Proc Cnt Last 90 Days],[EM 90 Day Proc Type Distribution Denom],0)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing\\Early Indicators"
              },
              {
                "name": "EM Proc Cnt",
                "expression": "CALCULATE([Proc Cnt], 'CPT Code'[Is EM Code]=\"True\")",
                "formatString": "#,0",
                "displayFolder": "Billing\\Early Indicators"
              },
              {
                "name": "Last Serv Date",
                "expression": [
                  "",
                  "CALCULATE (",
                  "    LASTDATE ( 'Date Of Service'[Serv Dte] ),",
                  "    FILTER (",
                  "        'Date Of Service',",
                  "        AND (",
                  "            'Date Of Service'[d_date_sk] = MAX ( '_Billing'[service_d_date_sk] ),",
                  "            'Date Of Service'[Serv Dte] <= TODAY ()",
                  "        )",
                  "    )",
                  ")"
                ],
                "formatString": "Short Date",
                "displayFolder": "Utilization\\Aging",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"DateTimeShortDatePattern\" />"
                  }
                ]
              },
              {
                "name": "Proc Type Distribution",
                "expression": [
                  "",
                  "DIVIDE (",
                  "    [Proc Cnt],",
                  "    CALCULATE ( [EM Proc Cnt], ALL ( 'CPT Code' ), 'CPT Code'[Is EM Code] = \"True\" ),",
                  "    BLANK ()",
                  ")"
                ],
                "displayFolder": "Billing\\Early Indicators"
              },
              {
                "name": "Proc Type StdDev Entry Date",
                "expression": [
                  "",
                  "STDEVX.S (",
                  "    GROUPBY (",
                  "        ADDCOLUMNS (VALUES( 'Date of Entry'[Entry Dte]), \"ptd\", [Proc Type Distribution] ),",
                  "        [ptd]",
                  "    ),",
                  "    [ptd]",
                  ")"
                ],
                "isHidden": true,
                "displayFolder": "Billing\\Early Indicators"
              },
              {
                "name": "Proc Type Std Dev Prior 90 Entry Date",
                "expression": [
                  "",
                  "CALCULATE (",
                  "    [Proc Type StdDev Entry Date],",
                  "    ALL ( 'Date of Entry' ),",
                  "    DATESINPERIOD (",
                  "        'Date of Entry'[Entry Dte],",
                  "        LASTDATE ( 'Date of Entry'[Entry Dte] ),",
                  "        -90,",
                  "        DAY",
                  "    )",
                  ")"
                ],
                "displayFolder": "Billing\\Early Indicators"
              },
              {
                "name": "Encounter with Actionable Denials",
                "expression": "CALCULATE([Encounter Cnt], 'Encounter'[Has Denials]=TRUE(),  'Denial Code'[Is Actionable]=TRUE())",
                "displayFolder": "Billing\\MOR"
              },
              {
                "name": "Bad Debt Rate % Calculated PR",
                "expression": " abs(DIVIDE([Bad Debt Writeoff], [Calc Patient Responsibility Amt],0))",
                "formatString": "0.00%;-0.00%;0.00%",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              },
              {
                "name": "Pat Resp Coll  % - Calculated PR",
                "expression": "ABS(DIVIDE([Net Pat Payment], [Calc Patient Responsibility Amt],0))",
                "formatString": "0.00%;-0.00%;0.00%",
                "displayFolder": "Financial\\Patient"
              },
              {
                "name": "Proc Type StdDev Entry Week",
                "expression": [
                  "",
                  "STDEVX.S (",
                  "    GROUPBY (",
                  "        ADDCOLUMNS (VALUES( 'Date of Entry'[Entry Wk Start Dte]), \"ptd\", [Proc Type Distribution] ),",
                  "        [ptd]",
                  "    ),",
                  "    [ptd]",
                  ")"
                ],
                "displayFolder": "Billing\\Early Indicators"
              },
              {
                "name": "Proc Type Std Dev Prior 13 Weeks",
                "expression": [
                  "",
                  "CALCULATE (",
                  "    [Proc Type StdDev Entry Week],",
                  "    ALL ( 'Date of Entry' ),",
                  "    DATESINPERIOD (",
                  "        'Date of Entry'[Entry Wk Start Dte],",
                  "        LASTDATE ( 'Date of Entry'[Entry Wk Start Dte] ),",
                  "        -91,",
                  "      DAY  ",
                  "    )",
                  ")"
                ],
                "displayFolder": "Billing\\Early Indicators"
              },
              {
                "name": "EM 90 Day Proc Type Distribution Denom",
                "expression": "CALCULATE([EM Proc Cnt Last 90 Days], ALL('CPT Code'))",
                "displayFolder": "Billing\\Early Indicators"
              },
              {
                "name": "Total Case % > 0% Pat Coll",
                "description": "Percentage of cases where patient collection rate is greater than 0% and patient responsibility is greater than 0",
                "expression": " DIVIDE([Total Cases > 0% Pat Coll], CALCULATE([Total Cases], Encounter[Pat Resp Status] <> \"No Pat Resp\"), 0)",
                "formatString": "0.00%;-0.00%;0.00%",
                "displayFolder": "Utilization\\Cases\\Statistics"
              },
              {
                "name": "Total Case % >= 95% Pat Coll",
                "description": "Percentage of cases where patient collection rate is greater than 0% and patient responsibility is greater than 0",
                "expression": " DIVIDE([Total Cases >= 95% Pat Coll], CALCULATE([Total Cases], Encounter[Pat Resp Status] <> \"No Pat Resp\"), 0)",
                "formatString": "0.00%;-0.00%;0.00%",
                "displayFolder": "Utilization\\Cases\\Statistics"
              },
              {
                "name": "Total Cases >= 95% Pat Coll",
                "description": "Total number of cases where patient collection rate is at least 95% and patient responsibility is greater than 0",
                "expression": [
                  "",
                  "CALCULATE([Total Cases], 'Encounter'[patient_responsbility_collection_pct]>0.94)"
                ],
                "formatString": "#,0",
                "displayFolder": "Utilization\\Cases\\Statistics"
              },
              {
                "name": "Total Cases > 0% Pat Coll",
                "description": "Total number of cases where patient collection rate is greater than 0% and patient responsibility is greater than 0",
                "expression": [
                  "",
                  "CALCULATE([Total Cases], 'Encounter'[patient_responsbility_collection_pct]>0)"
                ],
                "formatString": "#,0",
                "displayFolder": "Utilization\\Cases\\Statistics"
              },
              {
                "name": "Net Pmt for Expected Coll",
                "expression": [
                  "",
                  "VAR Mnths_17_Rolling =\t\t\t\t",
                  "\tIF(ISBLANK([Net Payment (+)]),BLANK(),",
                  "\tCALCULATE([Net Payment (+)],",
                  "\t\tDATESBETWEEN('Date Of Service'[Serv Dte],",
                  "\t\t\tENDOFMONTH(DATEADD('Date Of Service'[Serv Dte],-18,MONTH)) +1,",
                  "\t\t\tLASTDATE('Date Of Service'[Serv Dte]))))",
                  "\t\t\t",
                  "VAR Mnths_5_Rolling =IF(ISBLANK([Net Payment (+)]),BLANK(),",
                  "\tCALCULATE([Net Payment (+)],",
                  "\t\tDATESBETWEEN('Date Of Service'[Serv Dte],",
                  "\t\t\tENDOFMONTH(DATEADD('Date Of Service'[Serv Dte],-6,MONTH)) +1,",
                  "\t\t\tLASTDATE('Date Of Service'[Serv Dte]))))",
                  "Return Mnths_17_Rolling-Mnths_5_Rolling"
                ],
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Expected Coll Amt",
                "expression": " ([Avg Net Pmt Coll Rate %]*[Gross Charge])",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Payments",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Avg Net Pmt Coll Rate %",
                "expression": "DIVIDE([Net Pmt for Expected Coll],[Gross Charge for Expected Coll],0)",
                "formatString": "0.00%;-0.00%;0.00%",
                "displayFolder": "Financial\\Payments"
              },
              {
                "name": "Gross Charge for Expected Coll",
                "expression": [
                  "",
                  "VAR Mnths_17_Rolling =\t\t\t\t",
                  "\tIF(ISBLANK([Gross Charge]),BLANK(),",
                  "\tCALCULATE([Gross Charge],",
                  "\t\tDATESBETWEEN('Date Of Service'[Serv Dte],",
                  "\t\t\tENDOFMONTH(DATEADD('Date Of Service'[Serv Dte],-18,MONTH)) +1,",
                  "\t\t\tLASTDATE('Date Of Service'[Serv Dte]))))",
                  "\t\t\t",
                  "VAR Mnths_5_Rolling =IF(ISBLANK([Gross Charge]),BLANK(),",
                  "\tCALCULATE([Gross Charge],",
                  "\t\tDATESBETWEEN('Date Of Service'[Serv Dte],",
                  "\t\t\tENDOFMONTH(DATEADD('Date Of Service'[Serv Dte],-6,MONTH)) +1,",
                  "\t\t\tLASTDATE('Date Of Service'[Serv Dte]))))",
                  "Return Mnths_17_Rolling-Mnths_5_Rolling"
                ],
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Payments",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Reason Code Cnt",
                "expression": [
                  "",
                  "SUMMARIZE (",
                  "\tFILTER('Reason Code',",
                  "\t\t'Reason Code'[Reason Code] = \"73\"",
                  "\t\t||'Reason Code'[Reason Code] = \"75\"",
                  "\t\t||'Reason Code'[Reason Code] = \"77\"",
                  "\t\t||'Reason Code'[Reason Code] = \"79\"",
                  "\t\t||'Reason Code'[Reason Code] = \"82\"",
                  "\t\t||'Reason Code'[Reason Code] = \"84\"",
                  "\t\t||'Reason Code'[Reason Code] = \"87\"",
                  "\t\t||'Reason Code'[Reason Code] = \"93\"",
                  "\t\t||'Reason Code'[Reason Code] = \"94\"",
                  "\t\t||'Reason Code'[Reason Code] = \"98\"",
                  "\t\t||'Reason Code'[Reason Code] = \"101\"",
                  "\t\t||'Reason Code'[Reason Code] = \"102\"",
                  "\t\t||'Reason Code'[Reason Code] = \"103\"",
                  "\t\t||'Reason Code'[Reason Code] = \"104\"",
                  "\t\t||'Reason Code'[Reason Code] = \"105\"",
                  "\t\t||'Reason Code'[Reason Code] = \"108\"",
                  "\t\t||'Reason Code'[Reason Code] = \"109\"",
                  "\t\t)",
                  "\t\t,\"Reason Code Cnt\",[Total Cases]",
                  ")"
                ],
                "formatString": "#,0",
                "displayFolder": "Utilization"
              },
              {
                "name": "Reason Code Cnt NB",
                "expression": [
                  "",
                  "SUMMARIZE (",
                  "\tFILTER('Reason Code',",
                  "\t\t'Reason Code'[Reason Code] = \"106\"",
                  "\t\t||'Reason Code'[Reason Code] = \"107\"",
                  "\t\t)",
                  "\t\t,\"Reason Code Cnt NB\",[Total Cases]",
                  ")"
                ],
                "formatString": "#,0",
                "displayFolder": "Utilization"
              },
              {
                "name": "National RVU",
                "expression": "SUM(_Billing[total_national_rvu])",
                "formatString": "0.00",
                "displayFolder": "Utilization\\RVUs"
              },
              {
                "name": "Legacy Base Units",
                "expression": "  SUM([legacy_base_units])",
                "formatString": "0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Legacy Total Minutes",
                "expression": "  SUM([legacy_total_minutes])",
                "formatString": "0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Legacy Phys Status Units",
                "expression": "  SUM([legacy_physical_status_units])",
                "formatString": "0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Legacy Total Units",
                "expression": "  SUM([legacy_time_units])",
                "formatString": "0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Legacy Time Units",
                "expression": "  SUM([legacy_total_units])",
                "formatString": "0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Legacy Proc Cnt",
                "expression": "  SUM([legacy_procedure_count])",
                "formatString": "0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Legacy Total Case Cnt",
                "expression": "  SUM(_Billing[legacy_total_case_count])",
                "formatString": "0",
                "displayFolder": "Utilization\\Units"
              }
            ],
