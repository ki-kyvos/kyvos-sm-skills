                "dataView": "full",
                "source": {
                  "type": "query",
                  "query": [
                    "SELECT",
                    "\tdau.d_account_unit_sk",
                    "\t,management_consol\t\t\"Legal Management Consol\"",
                    "\t,FY_cs_definition\t\t\t\"Legal FY CS Defn\"",
                    "\t,FY_1_cs_definition\t\t\t\"Legal FY-1 CS Defn\"",
                    "\t,FY_2_cs_definition\t\t\t\"Legal FY-2 CS Defn\"",
                    "\t,FY_3_cs_definition\t\t\t\"Legal FY-3 CS Defn\"",
                    "\t,FY_4_cs_definition\t\t\t\"Legal FY-4 CS Defn\"",
                    "\t,member_name",
                    "\t,parent_name\t\t\t\"Legal Parent Name\"",
                    "\t,member_desc\t\t\t\"Legal Member Desc\"",
                    "\t,generation_num\t\t\t\"Legal Generation Num\"",
                    "\t,generation\t\t\t\"Legal Generation\"",
                    "\t,level\t\t\t\t\"Legal Level\"",
                    "\t,num_of_children\t\t\t\"Legal Num of Children\"",
                    "\t,acquisition_org\t\t\t\"Legal Acquisition Org\"",
                    "\t,acquisition_group\t\t\t\"Legal Acquisition Group\"",
                    "\t,start_date\t\t\t\"Legal Start Date\"",
                    "\t,term_date\t\t\t\"Legal Term Date\"",
                    "\t,award_date\t\t\t\"Legal Award Date\"",
                    "\t,affiliation\t\t\t\t\"Legal Affiliation\"",
                    "\t,billing_info\t\t\t\"Legal Billing Info\"",
                    "\t,incentive\t\t\t\t\"Legal Incentive\"",
                    "\t,subsidy\t\t\t\t\"Legal Subsidy\"",
                    "\t,jvorg\t\t\t\t\"Legal JVORG\"",
                    "\t,hyp.state\t\t\t\t\"Legal State\"",
                    "",
                    "FROM EDW_INT.dbo.vd_hyp_coau_hier_legal hyp",
                    "JOIN EDW_INT.dbo.vd_account_unit dau",
                    "ON hyp.member_name = dau.company_acct_unit"
                  ],
                  "dataSource": "EDW_INT"
                }
              }
            ],
