                  "type": "query",
                  "query": [
                    "",
                    "SELECT",
                    "\t d_time_sk\t\t\t\"time_sk\"",
                    "\t,time_12_long\t\t\t\"Start Time\"",
                    "\t,time_24_hour_short_1\t\t\"Start Hr\"",
