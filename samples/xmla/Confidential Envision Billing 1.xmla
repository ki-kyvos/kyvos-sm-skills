            "partitions": [
              {
                "name": "Patient",
                "dataView": "full",
                "source": {
                  "type": "query",
                  "query": [
                    "SELECT ",
                    "\t d_patient_sk",
                    "\t,lib\t\t\t\t\"Pat Lib\"",
                    "\t,patient_acct_num_highid\t\t\"Pat Acct Num High\"",
                    "\t,patient_acct_num_lowid\t\t\"Pat Acct Num Low\"",
                    "\t,patient_account_num\t\t\"Pat Acct Num\"",
                    "\t,account_num\t\t\t\"Account Number\"",
                    "\t,first_name\t\t\t\"Pat First Name\"",
                    "\t,last_name\t\t\t\"Pat Last Name\"",
                    "\t,middle_name\t\t\t\"Pat Middle Name\"",
                    "\t,suffix_name\t\t\t\"Pat Suffix\"",
                    "\t,birth_date\t\t\t\"Pat Birth Dte\"",
                    "\t,employment_status\t\t\t\"Pat Employment Status\"",
                    "\t,gender\t\t\t\t\"Pat Gender\"",
                    "\t,marital_status\t\t\t\"Pat Marital Status\"",
                    "\t,address_1\t\t\t\"Pat Address\"",
                    "\t,address_2\t\t\t\"Pat Address 2\"",
                    "\t,address_3\t\t\t\"Pat Address 3\"",
                    "\t,city\t\t\t\t\"Pat City\"",
                    "\t,state\t\t\t\t\"Pat State\"",
                    "\t,zip\t\t\t\t\"Pat Zip\"",
                    "\t,county\t\t\t\t \"Pat County\"",
                    "\t,patient_age_group\t\t\t\"Pat Age Group\"",
                    "\t,service_date\t\t\t\"Pat Service Dte\"",
                    "\t,country\t\t\t\t\"Pat Country\"",
                    "\t,mrn\t\t\t\t\"MRN\"",
                    "\t,propensity2payscore\t\t\"Propensity to Pay\"",
                    "",
                    "FROM EDW_INT.dbo.vd_patient",
                    "WHERE Billing_System != 'IQ'",
                    "",
