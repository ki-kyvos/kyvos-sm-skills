                    "\t,net_patient_payment_days_to_bad_debt_writeoff",
                    "\t,before_or_after_bad_debt_writeoff\t\t\"Writeoff Point Flag\"",
                    "\t,secondary_d_provider_sk",
                    "\t,d_facility_provider_sk",
                    "\t,supervision_level\t\t\t\t\"Supervision Level\"",
                    "\t,coding_qa_status\t\t\t\t\"Coding QA Status\"",
                    "\t,is_billed\t\t\t\t\t\"Is Billed\"",
                    "\t,downcode_from\t\t\t\t\"Downcode From\"",
                    "\t,downcode_lost_rvu",
                    "\t,downcode_reasons\t\t\t\"Downcode Reason\"",
                    "\t,charge_correct_flag\t\t\t\"Charge Correction Flag\"",
                    "\t,department_code\t\t\t\t\"Department Code\"",
                    "\t,secondary_midlevel_d_provider_sk",
                    "\t,actual_cpt_code_geographical_area                               ",
                    "\t,group_number\t\t\t\t\"Group Number\"",
                    "\t,group_name\t\t\t\t\"Group Name\"",
                    "\t,group_tax_id\t\t\t\t\"Group Tax ID\"",
                    "\t,group_npi\t\t\t\t\"Group NPI\"",
                    "\t,primary_payment_d_insurance_sk",
                    "\t,primary_payment_d_payer_product_sk      ",
                    "\t,total_national_rvu",
                    "\t,primary_d_financial_class_sk",
                    "\t,secondary_d_financial_class_sk",
                    "\t,tertiary_d_financial_class_sk",
                    "\t, legacy_base_units",
                    "\t,legacy_total_minutes",
                    "\t,legacy_physical_status_units",
                    "\t,legacy_total_units",
                    "\t,legacy_time_units",
                    "\t,legacy_procedure_count",
                    "\t,legacy_total_case_count",
                    "",
                    ", is_ob \"Is OB\"FROM EDW_INT.dbo.DT_RTI_BILLING ",
                    "WHERE partition_sequence = 6 ;"
                  ],
                  "dataSource": "EDW_INT"
                }
              },
