            "partitions": [
              {
                "name": "Time 15",
                "dataView": "full",
                "source": {
                  "type": "query",
                  "query": [
                    "SELECT ",
                    "\t d_time_sk                                     \t\t\t\"time_sk\"",
                    "\t,bucket",
                    "\t,time_12_long \t\t\t\t\t\t\t\"Time\"",
                    "\t,time_12_hour \t\t\t\t\t\t\t\"Time 12-Hour\"",
                    "\t,time_hour \t\t\t\t\t\t\t\"Time Hour\"",
                    "\t,time_12_long_15_min_interval\t\t\t\t\t\"Time 15-Min Interval\"",
                    "\t,time_12_hour_15_min_interval\t\t\t\t\t\"Time Hour 15 Min Interval\"",
                    "\t,d_time_sk_15_min_interval\t\t\t\t\t\"time_sk_15_min_interval\"\t",
                    "\t--,TO_TIME(time_12_long_15_min_interval)\t        \t\"Time 15\"",
                    "\t,time_12_long_15_min_interval\t        \t\t\t\"Time 15\"",
                    "\t,d_time_sk_30_min_interval\t\t\t\t\t\"time_sk_30_min_interval\"",
                    "\t,time_12_long_30_min_interval\t\t\t\t\t\"Time 30-Min Interval\"",
                    "\t,time_12_hour_30_min_interval\t\t\t\t\t\"Time Hour 30-Min Interval\"",
                    "",
                    "FROM EDW_INT.dbo.vd_time_5 WHERE time_12_long_15_min_interval <> 'NA' ;"
                  ],
                  "dataSource": "EDW_INT"
                }
              }
            ],
            "annotations": [
              {
                "name": "_TM_ExtProp_DbTableName",
                "value": "Time 15"
              },
              {
                "name": "_TM_ExtProp_QueryDefinition",
                "value": [
                  "SELECT ",
                  "\ttime_sk, ",
                  "\tbucket,  ",
                  "\ttime_12_long \tAS [Time],",
                  "\t[time_12_hour] \tAS [Time 12-Hour],",
                  "\t[time_hour] \tAS [Time Hour],",
                  "\t[time_12_long_15_min_interval] AS [Time 15-Min Interval],",
                  "\t[time_12_hour_15_min_interval] AS [Time Hour 15 Min Interval],",
                  "\ttime_sk_15_min_interval,",
                  "\tCAST([time_12_long_15_min_interval] as datetime) as [Time 15]",
                  "\t,[time_sk_30_min_interval]",
                  "\t,[time_12_long_30_min_interval] AS [Time 30-Min Interval]",
                  "\t,[time_12_hour_30_min_interval] AS [Time Hour 30-Min Interval]",
                  "",
                  "FROM ",
                  "\tdbo.vd_time_5 WITH (NOLOCK)"
                ]
              },
              {
                "name": "QueryEditorSerialization",
                "value": [
                  "<?xml version=\"1.0\" encoding=\"UTF-16\"?><Gemini xmlns=\"QueryEditorSerialization\"><AnnotationContent><![CDATA[<RSQueryCommandText>SELECT ",
                  "\ttime_sk, ",
                  "\tbucket,  ",
                  "\ttime_12_long \tAS [Time],",
                  "\t[time_12_hour] \tAS [Time 12-Hour],",
                  "\t[time_hour] \tAS [Time Hour],",
                  "\t[time_12_long_15_min_interval] AS [Time 15-Min Interval],",
                  "\t[time_12_hour_15_min_interval] AS [Time Hour 15 Min Interval],",
                  "\ttime_sk_15_min_interval,",
                  "\tCAST([time_12_long_15_min_interval] as datetime) as [Time 15]",
                  "\t,[time_sk_30_min_interval]",
                  "\t,[time_12_long_30_min_interval] AS [Time 30-Min Interval]",
                  "\t,[time_12_hour_30_min_interval] AS [Time Hour 30-Min Interval]",
                  "",
                  "FROM ",
                  "\tdbo.vd_time_5 WITH (NOLOCK)</RSQueryCommandText><RSQueryCommandType>Text</RSQueryCommandType><RSQueryDesignState></RSQueryDesignState>]]></AnnotationContent></Gemini>"
                ]
              }
            ]
