          {
            "name": "_Billing Encounter Summary",
            "columns": [
              {
                "name": "etl_src",
                "dataType": "string",
                "isHidden": true,
                "sourceColumn": "etl_src",
                "sourceProviderType": "VarChar"
              },
              {
                "name": "encounter_num",
                "dataType": "string",
                "isHidden": true,
                "sourceColumn": "encounter_num",
                "sourceProviderType": "VarChar"
              },
              {
                "name": "allowable_amt",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "allowable_amt",
                "sourceProviderType": "Decimal"
              },
              {
                "name": "service_d_date_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "service_d_date_sk",
                "sourceProviderType": "Integer"
              },
              {
                "name": "d_facility_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "d_facility_sk",
                "sourceProviderType": "Integer"
              },
              {
                "name": "expected_amt",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "expected_amt"
              },
              {
                "name": "insurance_responsibility_amt",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "insurance_responsibility_amt"
              },
              {
                "name": "calculated_patient_responsibility_amt",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "calculated_patient_responsibility_amt"
              },
              {
                "name": "total_acuity",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "total_acuity"
              },
              {
                "name": "billing_system_encounter_num",
                "dataType": "string",
                "isHidden": true,
                "sourceColumn": "billing_system_encounter_num"
              },
              {
                "name": "d_payer_product_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "d_payer_product_sk"
              },
              {
                "name": "primary_payment_d_payer_product_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "primary_payment_d_payer_product_sk"
              }
            ],
            "partitions": [
              {
                "name": "_Billing Encounter Summary",
                "dataView": "full",
                "source": {
                  "type": "query",
                  "query": [
                    "SELECT ",
                    "\t billing_system  \"etl_src\"",
                    "\t,encounter_num ",
                    "\t,allowable_amt ",
                    "\t,service_d_date_sk ",
                    "\t,d_facility_sk",
                    "\t,total_acuity",
                    "\t,expected_amt",
                    "\t,insurance_responsibility_amt",
                    "\t,calculated_patient_responsibility_amt",
                    "\t,billing_system_encounter_num",
                    "\t,d_payer_product_sk",
                    "\t,primary_payment_d_payer_product_sk\t",
                    "",
                    "FROM EDW_INT.dbo.vf_billing_encounter_summary"
                  ],
                  "dataSource": "EDW_INT"
                }
              }
            ],
            "measures": [
              {
                "name": "Allowable Amt",
                "expression": "SUM([allowable_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Acuity Per Case",
                "expression": "DIVIDE(SUM([total_acuity]),[Total Cases],0)",
                "formatString": "#,0.00",
                "displayFolder": "Billing Encounter Summary\\MOR"
              },
              {
                "name": "Expected Amt",
                "expression": "SUM([expected_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Ins Responsibility Amt",
                "expression": "SUM([insurance_responsibility_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Calc Patient Responsibility Amt",
                "expression": "SUM([calculated_patient_responsibility_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Ins Exp CPV",
                "expression": "DIVIDE([Ins Responsibility Amt],[Total Cases],0)",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Ins Act CPV",
                "expression": "ABS(DIVIDE([Net Ins Payment],[Total Cases],0))",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Pat Exp CPV",
                "expression": "ABS(DIVIDE([Calc Patient Responsibility Amt],[Total Cases],0))",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Total Exp CPV",
                "expression": "DIVIDE([Expected Amt],[Total Cases],0)",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Total Act CPV",
                "expression": "DIVIDE([Net Payment (+)],[Total Cases],0)",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Ins RR %",
                "expression": "ABS(DIVIDE([Net Ins Payment],[Ins Responsibility Amt],0))",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing Encounter Summary\\MOR"
              },
              {
                "name": "Pat RR %",
                "expression": "ABS(DIVIDE([Net Pat Payment],[Calc Patient Responsibility Amt],0))",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing Encounter Summary\\MOR"
              },
              {
                "name": "Total RR %",
                "expression": " ABS(DIVIDE([Net Payment],[Expected Amt],0))",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing Encounter Summary\\MOR"
              },
              {
                "name": "Pat Act CPV",
                "expression": "ABS(DIVIDE([Net Pat Payment],[Total Cases],0))",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Ins CPV Var Impact",
                "expression": " ([Ins Act CPV]-[Ins Exp CPV])*[Total Cases]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Pat CPV Var Impact",
                "expression": " ([Pat Act CPV]-[Pat Exp CPV])*[Total Cases]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "CPV Var Impact",
                "expression": " ([Total Act CPV]-[Total Exp CPV])*[Total Cases]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Billing Encounter Summary\\MOR",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Total Acuity",
                "description": "Total Acuity by Encounter level",
                "expression": "sum('_Billing Encounter Summary'[total_acuity])",
                "displayFolder": "Billing Encounter Summary\\MOR"
              },
              {
                "name": "Total Acuity by CPT",
                "description": "Total Acuity by CPT level",
                "expression": "SUMX(SUMMARIZE(_Billing, 'Facility'[Fac LOB], \"ACP\", IF('Facility'[Fac LOB]=\"ANES\",[Total Units - Norm], [Wrk RVU])), [ACP])",
                "formatString": "#,0.00",
                "displayFolder": "Billing Encounter Summary\\MOR"
              },
              {
                "name": "Pat Bad Debt Rate % - Calculated PR",
                "description": "Bad Debt Rate % - Calculated PR at patient level",
                "expression": " ABS(DIVIDE([Pat Bad Debt Writeoff], [Calc Patient Responsibility Amt], 0))",
                "formatString": "0.00%;-0.00%;0.00%",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              }
            ],
            "annotations": [
              {
                "name": "_TM_ExtProp_QueryDefinition",
