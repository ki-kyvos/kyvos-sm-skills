            ],
            "measures": [
              {
                "name": "Contr Allowed",
                "expression": "SUM([reimbursement_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Contractual",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Gross Charge",
                "expression": "SUM([charge_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Charges",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Ins Payment",
                "expression": "SUM([insurance_payment_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments\\Insurance",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Pat Payment",
                "expression": "SUM([patient_payment_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments\\Patient",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Ins Refund",
                "expression": "SUM([insurance_refund_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments\\Insurance",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Pat Refund",
                "expression": "SUM([patient_refund_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments\\Patient",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Pat Adjustment",
                "expression": "SUM([payment_adjustment_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Adjustments\\Contractual",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Other Writeoff",
                "expression": "SUM([other_writeoff_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Adjustments\\Contractual",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Record Cnt",
                "expression": "COUNTROWS('_Billing')",
                "formatString": "#,0",
                "displayFolder": "Utilization"
              },
              {
                "name": "Non Fac RVU",
                "expression": "SUM([non_facility_rvu])",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\RVUs"
              },
              {
                "name": "Total RVU",
                "expression": "SUM([total_rvu])",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\RVUs"
              },
              {
                "name": "Wrk RVU",
                "expression": "SUM([work_rvu])",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\RVUs"
              },
              {
                "name": "Base Units",
                "expression": "SUM([base_units])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Time Units Billed",
                "expression": "SUM([time_units])",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Total Units",
                "expression": "SUM([total_units])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Total Minutes",
                "expression": "SUM([total_minutes])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Denied Chg",
                "expression": "SUM([denial_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Operational\\Denials",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Net Billed",
                "expression": "SUM([net_billed_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Net Billed",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Total Balance",
                "expression": "SUM([balance_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Balance",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Total Cases",
                "expression": "SUM([total_case_count])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Cases"
              },
              {
                "name": "Out Cases",
                "expression": "SUM([outcase_count])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Cases"
              },
              {
                "name": "In Cases",
                "expression": "SUM([incase_count])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Cases"
              },
              {
                "name": "Total Days To Post",
                "expression": "SUM([days_to_post])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Aging"
              },
              {
                "name": "Net Pmt Coll %",
                "expression": "DIVIDE( -([Net Payment] ), [Gross Charge], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments"
              },
              {
                "name": "Net Payment",
                "expression": "SUM([Net_Payment_Amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Payment",
                "expression": "[Pat Payment] + [Ins Payment]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Nurse Proc Cnt",
                "expression": "SUM([nurse_proc_count])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Procedures"
              },
              {
                "name": "Nurse Proc Lvl 1 Cnt",
                "expression": "SUM([nurse_proc_count_lvl_1])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Procedures"
              },
              {
                "name": "Gross Charge - Norm",
                "expression": "SUM([normalized_charge_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Charges",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Pmt Rate - Norm",
                "expression": "DIVIDE(-[Payment], [Gross Charge - Norm], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments"
              },
              {
                "name": "Pmt Rate",
                "expression": "DIVIDE(-[Payment], [Gross Charge], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments"
              },
              {
                "name": "Contr % - Norm",
                "expression": "ROUND(DIVIDE([Contr Allowed],[Gross Charge - Norm], BLANK()),4)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Contractual"
              },
              {
                "name": "Contr %",
                "expression": "DIVIDE([Contr Allowed],[Gross Charge], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Contractual"
              },
              {
                "name": "Net Ins Payment",
                "expression": "[Ins Payment] + [Ins Refund]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments\\Insurance",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Total Adjustment",
                "expression": "SUM([total_adjustment_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Adjustments",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Net Pat Payment",
                "expression": "[Pat Payment] + [Pat Refund]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments\\Patient",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Time Units 10",
                "expression": "SUM([time_units_10])",
                "formatString": "#,0.00000",
                "displayFolder": "Utilization\\Units\\10 Minute"
              },
              {
                "name": "Time Units 10 Rnd",
                "expression": "SUM([time_units_10_rnd])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Units\\10 Minute"
              },
              {
                "name": "Time Units 10 Rnd up",
                "expression": "SUM([time_units_10_rnd_up])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Units\\10 Minute"
              },
              {
                "name": "Time Units 10 Rnd dn",
                "expression": "SUM([time_units_10_rnd_down])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Units\\10 Minute"
              },
              {
                "name": "Time Units 10 Rnd tenth",
                "expression": "SUM([time_units_10_rnd_tenth])",
                "formatString": "#,0.0",
                "displayFolder": "Utilization\\Units\\10 Minute"
              },
              {
                "name": "Time Units 15",
                "expression": "SUM([time_units_15])",
                "formatString": "#,0.00000",
                "displayFolder": "Utilization\\Units\\15 Minute"
              },
              {
                "name": "Time Units 15 Rnd",
                "expression": "SUM([time_units_15_rnd])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Units\\15 Minute"
              },
              {
                "name": "Time Units 15 Rnd up",
                "expression": "SUM([time_units_15_rnd_up])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Units\\15 Minute"
              },
              {
                "name": "Time Units 15 Rnd dn",
                "expression": "SUM([time_units_15_rnd_down])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Units\\15 Minute"
              },
              {
                "name": "Time Units 15 Rnd tenth",
                "expression": "SUM([time_units_15_rnd_tenth])",
                "formatString": "#,0.0",
                "displayFolder": "Utilization\\Units\\15 Minute"
              },
              {
                "name": "Net Pat Payment Rel % of Tot",
                "expression": "DIVIDE([Net Pat Payment], CALCULATE([Net Pat Payment],ALL('_Billing'[DOS - DOE Mnth Diff])),BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Cumulative Net Pat Pmt Rel % Of Tot",
                "expression": [
                  "CALCULATE (",
                  "    [Net Pat Payment Rel % Of Tot],",
                  "    FILTER (",
                  "        ALL ( '_Billing'[DOS - DOE Mnth Diff] ),",
                  "        '_Billing'[DOS - DOE Mnth Diff] <= MAX ( '_Billing'[DOS - DOE Mnth Diff] )",
                  "    )",
                  ")"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Net Ins Payment Rel % of Tot",
                "expression": "DIVIDE([Net Ins Payment], CALCULATE([Net Ins Payment],ALL('_Billing'[DOS - DOE Mnth Diff])),BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Cumulative Net Ins Pmt Rel % Of Tot",
                "expression": [
                  "CALCULATE (",
                  "    [Net Ins Payment Rel % Of Tot],",
                  "    FILTER (",
                  "        ALL ( '_Billing'[DOS - DOE Mnth Diff] ),",
                  "        '_Billing'[DOS - DOE Mnth Diff] <= MAX ( '_Billing'[DOS - DOE Mnth Diff] )",
                  "    )",
                  ")"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Total Net Payment Rel % of Tot",
                "expression": "DIVIDE([Net Payment], CALCULATE([Net Payment],ALL('_Billing'[DOS - DOE Mnth Diff])),BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Cumulative Total Net Payment Rel % Of Tot",
                "expression": [
                  "CALCULATE (",
                  "    [Net Ins Payment Rel % Of Tot],",
                  "    FILTER (",
                  "        ALL ( '_Billing'[DOS - DOE Mnth Diff] ),",
                  "        '_Billing'[DOS - DOE Mnth Diff] <= MAX ( '_Billing'[DOS - DOE Mnth Diff] )",
                  "    )",
                  ")"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Bad Debt Writeoff",
                "expression": "SUM([bad_debt_writeoff_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Adjustments\\Bad Debt",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Bad Debt Writeoff Rel % of Tot",
                "expression": "DIVIDE([Bad Debt Writeoff], CALCULATE([Bad Debt Writeoff],ALL('_Billing'[DOS - DOE Mnth Diff])),BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Cumulative Bad Debt Writeoff Rel % Of Tot",
                "expression": [
                  "CALCULATE (",
                  "    [Bad Debt Writeoff Rel % Of Tot],",
                  "    FILTER (",
                  "        ALL ( '_Billing'[DOS - DOE Mnth Diff] ),",
                  "        '_Billing'[DOS - DOE Mnth Diff] <= MAX ( '_Billing'[DOS - DOE Mnth Diff] )",
                  "    )",
                  ")"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Total Adjustment Rel % of Tot",
                "expression": "DIVIDE([Total Adjustment], CALCULATE([Total Adjustment],ALL('_Billing'[DOS - DOE Mnth Diff])),BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Cumulative Total Adjustment Rel % Of Tot",
                "expression": [
                  "CALCULATE (",
                  "    [Total Adjustment Rel % Of Tot],",
                  "    FILTER (",
                  "        ALL ( '_Billing'[DOS - DOE Mnth Diff] ),",
                  "        '_Billing'[DOS - DOE Mnth Diff] <= MAX ( '_Billing'[DOS - DOE Mnth Diff] )",
                  "    )",
                  ")"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Contr Adjustment",
                "expression": "SUM([contractual_adjustment_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Adjustments\\Contractual",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Contractual Adj Rel % of Tot",
                "expression": "DIVIDE([Contr Adjustment], CALCULATE([Contr Adjustment],ALL('_Billing'[DOS - DOE Mnth Diff])),BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Cumulative Contractual Adj Rel % Of Tot",
                "expression": [
                  "CALCULATE (",
                  "    [Contractual Adj Rel % Of Tot],",
                  "    FILTER (",
                  "        ALL ( '_Billing'[DOS - DOE Mnth Diff] ),",
                  "        '_Billing'[DOS - DOE Mnth Diff] <= MAX ( '_Billing'[DOS - DOE Mnth Diff] )",
                  "    )",
                  ")"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Contr Adj %",
                "expression": "DIVIDE( (-[Contr Adj Numerator]),[Gross Charge], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Contractual"
              },
              {
                "name": "Total Units - Norm",
                "expression": "([Base Units] + [Time Units 15 rnd up])+ [Phys Status Units]",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Avg Days To Enter",
                "expression": "DIVIDE( [Total Days To Enter], [Total Cases],BLANK())",
                "formatString": "#,0.00",
                "displayFolder": "Operational\\Aging"
              },
              {
                "name": "Total Days To Enter",
                "expression": "SUM([days_to_enter])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Aging"
              },
              {
                "name": "Avg Days To Post",
                "expression": "IF([Proc Cnt] =0 || [Proc Cnt] = BLANK(), BLANK(), DIVIDE([Total Days To Post] , [Proc Cnt], 0))",
                "formatString": "#,0.00",
                "displayFolder": "Operational\\Aging"
              },
              {
                "name": "Pat Resp Bad Debt %",
                "expression": "DIVIDE( - [Bad Debt Writeoff],  [Pat Responsibility], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Patient"
              },
              {
                "name": "Pat Responsibility",
                "expression": "[Pat Balance] - [Net Pat Payment] - [Pat Bad Debt Writeoff]",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Patient",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Pat Resp Coll %",
                "expression": "IF([Pat Responsibility] = 0 || [Pat Responsibility] = BLANK(), BLANK(), -DIVIDE([Net Pat Payment], [Pat Responsibility], 0))",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Patient"
              },
              {
                "name": "Remaining Pat Bal %",
                "expression": "DIVIDE([Pat Balance],[Pat Responsibility], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Patient"
              },
              {
                "name": "Pat Resp % - Norm",
                "expression": "DIVIDE([Pat Responsibility], [Gross Charge - Norm], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Patient"
              },
              {
                "name": "Pat Resp %",
                "expression": "DIVIDE([Pat Responsibility], [Gross Charge], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Patient"
              },
              {
                "name": "Bad Debt Writeoff % Trailing 6 Mnth Chg Avg",
                "expression": "DIVIDE(-[Bad Debt Writeoff], [Trailing 6 Mnth Chg Avg], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              },
              {
                "name": "Trailing 6 Mnth Chg Avg",
                "expression": "DIVIDE([ChargesLast6Months],6, 0)",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Charges\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "ChargesLast6Months",
                "expression": [
                  "IF ( CALCULATE([Gross Charge], FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -6, MONTH ))) = 0  ||",
                  "       CALCULATE([Gross Charge], FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -5, MONTH ))) = 0  ||",
                  "       CALCULATE([Gross Charge], FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -4, MONTH ))) = 0  ||",
                  "       CALCULATE([Gross Charge], FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -3, MONTH ))) = 0  ||",
                  "       CALCULATE([Gross Charge], FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -2, MONTH ))) = 0  ||",
                  "       CALCULATE([Gross Charge], FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -1, MONTH ))) = 0 ,",
                  "       BLANK(),",
                  "    CALCULATE (",
                  "      [Gross Charge],",
                  "      DATESBETWEEN (",
                  "        'Date Of Accounting Month'[Acctg Dte],",
                  "          FIRSTDATE (DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -6, MONTH )),",
                  "          FIRSTDATE (DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -1, MONTH ))",
                  "      )",
                  "    )",
                  "  )"
                ],
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "isHidden": true,
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Other Writeoff %",
                "expression": "DIVIDE(-[Other Writeoff],[Gross Charge],BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Contractual"
              },
              {
                "name": "Other Writeoff % - Norm",
                "expression": "DIVIDE(-[Other Writeoff],[Gross Charge - Norm],BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Contractual"
              },
              {
                "name": "Bad Debt Writeoff %",
                "expression": "DIVIDE(-[Bad Debt Writeoff], [Gross Charge],BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              },
              {
                "name": "Bad Debt Writeoff % - Norm",
                "expression": "DIVIDE(-[Bad Debt Writeoff], [Gross Charge - Norm],BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              },
              {
                "name": "Net Pat Pmt Coll %",
                "expression": "DIVIDE( -[Net Pat Payment], [Gross Charge],BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Patient"
              },
              {
                "name": "Net Pat Pmt Coll % - Norm",
                "expression": "DIVIDE( -[Net Pat Payment], [Gross Charge - Norm],BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Patient"
              },
              {
                "name": "Net Ins Pmt Coll %",
                "expression": "DIVIDE( -[Net Ins Payment], [Gross Charge],BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Insurance"
              },
              {
                "name": "Net Ins Pmt Coll % - Norm",
                "expression": "DIVIDE( -[Net Ins Payment], [Gross Charge - Norm],BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Insurance"
              },
              {
                "name": "Trailing 3 Mnth Chg Avg",
                "expression": "DIVIDE ( [ChargesLast3Months], 3, BLANK() )",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Charges\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "ChargesLast3Months",
                "expression": [
                  "IF (",
                  "    CALCULATE (",
                  "        [Gross Charge],",
                  "        FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -3, MONTH ) )",
                  "    )",
                  "        = 0",
                  "        || CALCULATE (",
                  "            [Gross Charge],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -2, MONTH ) )",
                  "        )",
                  "            = 0",
                  "        || CALCULATE (",
                  "            [Gross Charge],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -1, MONTH ) )",
                  "        )",
                  "            = 0,",
                  "    BLANK (),",
                  "    CALCULATE (",
                  "        [Gross Charge],",
                  "        DATESBETWEEN (",
                  "            'Date Of Accounting Month'[Acctg Dte],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -3, MONTH ) ),",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -1, MONTH ) )",
                  "        )",
                  "    )",
                  ")"
                ],
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "isHidden": true,
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Trailing 3 Mnth Chg Avg - Norm",
                "expression": "DIVIDE([ChargesLast3Months - Norm],3,BLANK())",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Charges\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Trailing 6 Mnth Chg Avg - Norm",
                "expression": [
                  "IF ( ",
                  "       CALCULATE( SUM ( [normalized_charge_amt] ), FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -6, MONTH ))) = 0  ||",
                  "       CALCULATE( SUM ( [normalized_charge_amt] ), FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -5, MONTH ))) = 0  ||",
                  "       CALCULATE( SUM ( [normalized_charge_amt] ), FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -4, MONTH ))) = 0  ||",
                  "       CALCULATE( SUM ( [normalized_charge_amt] ), FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -3, MONTH ))) = 0  ||",
                  "       CALCULATE( SUM ( [normalized_charge_amt] ), FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -2, MONTH ))) = 0  ||",
                  "       CALCULATE( SUM ( [normalized_charge_amt] ), FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -1, MONTH ))) = 0, BLANK(),",
                  "  DIVIDE(CALCULATE (",
                  "      SUM ( [normalized_charge_amt] ),",
                  "      DATESBETWEEN (",
                  "        'Date Of Accounting Month'[Acctg Dte],",
                  "          FIRSTDATE (DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -6, MONTH )),",
                  "          FIRSTDATE (DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -1, MONTH ))",
                  "      )",
                  "    ),6)",
                  ")"
                ],
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Charges\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Avg Chg / Case - Norm",
                "expression": "DIVIDE([Gross Charge - Norm],[Total Cases],BLANK())",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Charges",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Net Payment (+)",
                "expression": "-[Net Payment]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Refund",
                "expression": "[Pat Refund] + [Ins Refund]",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Avg Chg / Case",
                "expression": "DIVIDE([Gross Charge] , [Total Cases], BLANK())",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Charges",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Pat Balance",
                "expression": "SUM([patient_balance_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Balance",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Ins Balance",
                "expression": "SUM([insurance_balance_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Balance",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Contract Coll %",
                "expression": "DIVIDE([Net Payment], [Contr Balance], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Contr Balance",
                "expression": "SUM([contract_balance_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Contractual",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Proc Cnt",
                "expression": "SUM([procedure_count])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Procedures"
              },
              {
                "name": "Net Pmt Coll % - Norm",
                "expression": "DIVIDE( -([Net Payment] ), [Gross Charge - Norm], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments"
              },
              {
                "name": "Contr Adj % - Norm",
                "expression": "DIVIDE( -[Contr Adjustment],[Gross Charge - Norm], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Contractual"
              },
              {
                "name": "Phys Status Units",
                "expression": "SUM([physical_status_units])",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Denial Cnt",
                "expression": "SUM([denial_cnt])",
                "formatString": "#,0",
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "Misc Adjustment",
                "expression": "SUM([withhold_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Adjustments",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Contr Adj Numerator",
                "expression": "SUM([contractual_adjustment_numerator])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "isHidden": true,
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" ThousandSeparator=\"True\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Act Denials Num",
                "expression": "CALCULATE( [Denial Cnt], 'Denial Code'[Is Actionable] = True(), FILTER('Date Of Posting', 'Date Of Posting'[Posting Yr Mnth] = [RelatedAcctgMonth]), ALL('Date Of Accounting Month'), ALL('Date Of Service'))",
                "formatString": "#,0",
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "RelatedAcctgMonth",
                "expression": "TOPN(1,VALUES('Date Of Accounting Month'[Acctg Yr Mnth]),[Acctg Yr Mnth])",
                "isHidden": true
              },
              {
                "name": "Act Denials Denom",
                "expression": "CALCULATE([Total Cases], FILTER('Date Of Accounting Month', [Acctg Yr Mnth] = [RelatedAcctgMonth]), ALL('Denial Code'), ALL('Date Of Posting'), ALL('Date Of Service'))",
                "formatString": "#,0",
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "% Act Denials",
                "expression": "DIVIDE([Act Denials Num], [Act Denials Denom], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "Time Hrs",
                "expression": "SUM([time_hours])",
                "formatString": "#,0",
                "isHidden": true
              },
              {
                "name": "After Hours Cases - Count",
                "expression": "CALCULATE([Total Cases],FILTER(ALL('Time Of Procedure Start'),'Time Of Procedure Start'[Hour Type]=\"After Hours\"))",
                "displayFolder": "Financial\\Cases"
              },
              {
                "name": "After Hours Cases - Minutes",
                "expression": "CALCULATE([Total Minutes],FILTER(ALL('Time Of Procedure Start'),'Time Of Procedure Start'[Hour Type]=\"After Hours\"))",
                "displayFolder": "Financial\\Cases"
              },
              {
                "name": "Paid Claim Coll % - Norm",
                "expression": [
                  "- DIVIDE (",
                  "    CALCULATE (",
                  "        '_Billing'[Net Payment],",
                  "        '_Billing'[Account Balance Class] = \"Zero Balance\"",
                  "            || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"",
                  "            || '_Billing'[Account Balance Class] = \"Open Balance Short Paid\"",
                  "    ),",
                  "    CALCULATE (",
                  "        '_Billing'[Gross Charge - Norm],",
                  "        '_Billing'[Account Balance Class] = \"Zero Balance\"",
                  "            || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"",
                  "            || '_Billing'[Account Balance Class] = \"Open Balance Short Paid\"",
                  "    ),",
                  "    BLANK ()",
                  ")"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Group Avg Claim Coll % - Norm",
                "expression": [
                  "CALCULATE (",
                  "    [Paid Claim Coll % - Norm],",
                  "    ALL ( '_Billing' ),",
                  "    VALUES ( Facility[Fac State] ),",
                  "    VALUES ( 'Payer Product Primary'[Pri Payer Product Lvl 3] ),",
                  "    VALUES ( 'Date Of Service'[Serv Yr Mnth] )",
                  ")"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Group Avg v Paid Claim $ - Norm Impact",
                "expression": "([Group Avg Claim Coll % - Norm]-[Paid Claim Coll % - Norm])*[Gross Charge - Norm]",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Payments\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Paid Claim Coll %",
                "expression": [
                  "ROUND(- DIVIDE (",
                  "    CALCULATE (",
                  "        '_Billing'[Net Payment],",
                  "        '_Billing'[Account Balance Class] = \"Zero Balance\"",
                  "            || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"",
                  "            || '_Billing'[Account Balance Class] = \"Open Balance Short Paid\"",
                  "    ),",
                  "    CALCULATE (",
                  "        '_Billing'[Gross Charge],",
                  "        '_Billing'[Account Balance Class] = \"Zero Balance\"",
                  "            || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"",
                  "            || '_Billing'[Account Balance Class] = \"Open Balance Short Paid\"",
                  "    ),",
                  "    BLANK ()",
                  "),4)"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Resolved AR Coll %",
                "expression": "DIVIDE([Net Payment], ([Net Payment] + [Total Adjustment]) , BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Closed Claim Chg % - Norm",
                "expression": [
                  "DIVIDE(    CALCULATE('_Billing'[Gross Charge - Norm], '_Billing'[Account Balance Class] = \"Zero Balance\" || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"),",
                  "        [Gross Charge - Norm], BLANK() )"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "isHidden": true
              },
              {
                "name": "Closed Claim Chg %",
                "expression": [
                  "DIVIDE(    CALCULATE('_Billing'[Gross Charge], '_Billing'[Account Balance Class] = \"Zero Balance\" || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"),",
                  "        [Gross Charge], BLANK() )"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Closed Claim Coll % - Norm",
                "expression": [
                  "- DIVIDE( CALCULATE('_Billing'[Net Payment], '_Billing'[Account Balance Class] = \"Zero Balance\" || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"),",
                  "                           CALCULATE('_Billing'[Gross Charge - Norm], '_Billing'[Account Balance Class] = \"Zero Balance\" || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"), BLANK())"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Closed Claim Coll %",
                "expression": [
                  "- DIVIDE( CALCULATE('_Billing'[Net Payment], '_Billing'[Account Balance Class] = \"Zero Balance\" || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"),",
                  "                           CALCULATE('_Billing'[Gross Charge], '_Billing'[Account Balance Class] = \"Zero Balance\" || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"), BLANK())"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Paid Claim Chg % - Norm",
                "expression": [
                  "DIVIDE( CALCULATE('_Billing'[Gross Charge - Norm], '_Billing'[Account Balance Class] = \"Zero Balance\" || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"  || '_Billing'[Account Balance Class] = \"Open Balance Short Paid\") ",
                  "                                                    ,[Gross Charge - Norm]",
                  "                                                   ,BLANK())"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "isHidden": true
              },
              {
                "name": "Paid Claim Chg %",
                "expression": [
                  "DIVIDE( CALCULATE('_Billing'[Gross Charge], '_Billing'[Account Balance Class] = \"Zero Balance\" || '_Billing'[Account Balance Class] = \"Zero Balance Zero Paid\"  || '_Billing'[Account Balance Class] = \"Open Balance Short Paid\") ",
                  "                                                    ,[Gross Charge]",
                  "                                                   ,BLANK())"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Resolved AR Chg % - Norm",
                "expression": "DIVIDE(-([Net Payment] + [Total Adjustment]), [Gross Charge - Norm], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "isHidden": true
              },
              {
                "name": "Resolved AR Chg %",
                "expression": "DIVIDE(-([Net Payment] + [Total Adjustment]), [Gross Charge], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Short Paid Claim Chg % - Norm",
                "expression": [
                  "DIVIDE(    CALCULATE('_Billing'[Gross Charge - Norm], '_Billing'[Account Balance Class] = \"Open Balance Short Paid\"),",
                  "        [Gross Charge - Norm], BLANK() )"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "isHidden": true
              },
              {
                "name": "Short Paid Claim Chg %",
                "expression": [
                  "DIVIDE(    CALCULATE('_Billing'[Gross Charge], '_Billing'[Account Balance Class] = \"Open Balance Short Paid\"),",
                  "        [Gross Charge], BLANK() )"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Short Paid Coll % - Norm",
                "expression": [
                  "DIVIDE(- CALCULATE('_Billing'[Net Payment],  '_Billing'[Account Balance Class] = \"Open Balance Short Paid\"),",
                  "                           CALCULATE('_Billing'[Gross Charge - Norm], '_Billing'[Account Balance Class] = \"Open Balance Short Paid\"), BLANK())"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Short Paid Coll %",
                "expression": [
                  "DIVIDE(- CALCULATE('_Billing'[Net Payment],  '_Billing'[Account Balance Class] = \"Open Balance Short Paid\"),",
                  "                           CALCULATE('_Billing'[Gross Charge], '_Billing'[Account Balance Class] = \"Open Balance Short Paid\"), BLANK())"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Unpaid Claim Chg % - Norm",
                "expression": [
                  "DIVIDE(    CALCULATE('_Billing'[Gross Charge - Norm], '_Billing'[Account Balance Class] = \"Open Balance Zero Paid\"),",
                  "        [Gross Charge - Norm], BLANK() )"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "isHidden": true
              },
              {
                "name": "Unpaid Claim Chg %",
                "expression": [
                  "DIVIDE(    CALCULATE('_Billing'[Gross Charge], '_Billing'[Account Balance Class] = \"Open Balance Zero Paid\"),",
                  "        [Gross Charge], BLANK() )"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Net Pmt / Case",
                "expression": "ABS(DIVIDE([Net Payment], [Total Cases], BLANK()))",
                "displayFolder": "Financial\\Payments"
              },
              {
                "name": "Proc Cnt All Providers",
                "expression": "CALCULATE([Proc Cnt],ALL(Provider))",
                "formatString": "#,0",
                "displayFolder": "KD"
              },
              {
                "name": "Proc Cnt All Providers All Facilities",
                "expression": "CALCULATE([Proc Cnt], ALL(Provider), ALL(Facility))",
                "formatString": "#,0",
                "displayFolder": "KD"
              },
              {
                "name": "Avg Daily Case Cnt",
                "expression": "DIVIDE([Total Cases],DISTINCTCOUNT(_Billing[service_d_date_sk]),blank())",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\Cases"
              },
              {
                "name": "Doc Cnt All Dr",
                "expression": "CALCULATE(DISTINCTCOUNT([d_provider_sk]), ALL('_Billing'[d_provider_sk]))",
                "formatString": "#,0",
                "displayFolder": "Utilization"
              },
              {
                "name": "All Grp Wrk RVU",
                "expression": "CALCULATE([Wrk RVU], ALL('_Billing'[Misys Group Num]))",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\RVUs\\Productivity"
              },
              {
                "name": "CPT Line Cnt",
                "expression": "SUM([cpt_line_cnt])",
                "formatString": "#,0",
                "displayFolder": "Utilization\\Procedures"
              },
              {
                "name": "Total RVU Phy Comp Elig",
                "expression": "SUM([total_rvu_weight])",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\RVUs"
              },
              {
                "name": "Wrk RVU Phy Comp Elig",
                "expression": "SUM([work_rvu_weight])",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\RVUs"
              },
              {
                "name": "Avg Days to First Ins Pay",
                "expression": [
                  "CALCULATE (",
                  "    DIVIDE ( SUM ( [Days_To_first_Ins_Pay] ), [Total Cases], 0 ),",
                  "    _Billing[Days_To_first_Ins_Pay] <> -1",
                  ")"
                ],
                "formatString": "#,0.00",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Trailing 6 Mnth Bad Debt Writeoff Avg",
                "expression": [
                  "IF (",
                  "    CALCULATE (",
                  "        [Bad Debt Writeoff],",
                  "        FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -6, MONTH ) )",
                  "    )",
                  "        = 0",
                  "        || CALCULATE (",
                  "            [Bad Debt Writeoff],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -5, MONTH ) )",
                  "        )",
                  "            = 0",
                  "        || CALCULATE (",
                  "            [Bad Debt Writeoff],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -4, MONTH ) )",
                  "        )",
                  "            = 0",
                  "        || CALCULATE (",
                  "            [Bad Debt Writeoff],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -3, MONTH ) )",
                  "        )",
                  "            = 0",
                  "        || CALCULATE (",
                  "            [Bad Debt Writeoff],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -2, MONTH ) )",
                  "        )",
                  "            = 0",
                  "        || CALCULATE (",
                  "            [Bad Debt Writeoff],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -1, MONTH ) )",
                  "        )",
                  "            = 0,",
                  "    BLANK (),",
                  "    DIVIDE (",
                  "        CALCULATE (",
                  "            [Bad Debt Writeoff],",
                  "            DATESBETWEEN (",
                  "                'Date Of Accounting Month'[Acctg Dte],",
                  "                FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -6, MONTH ) ),",
                  "                FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -1, MONTH ) )",
                  "            )",
                  "        ),",
                  "        6",
                  "    )",
                  ")"
                ],
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Adjustments\\Bad Debt",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Bad Debt Writeoff % Trailing 6 Mnth Chg - Norm Avg",
                "expression": "DIVIDE(-[Bad Debt Writeoff], [Trailing 6 Mnth Chg Avg - Norm], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              },
              {
                "name": "Fac Dr Cnt",
                "expression": "CALCULATE ( DISTINCTCOUNT ( Provider[d_provider_sk] ), Filter('_Billing',RELATED(Provider[Prov Occup])=\"D\"))",
                "formatString": "0",
                "displayFolder": "Utilization"
              },
              {
                "name": "ChargesLast3Months - Norm",
                "expression": [
                  "IF (",
                  "    CALCULATE (",
                  "        [Gross Charge - Norm],",
                  "        FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -3, MONTH ) )",
                  "    )",
                  "        = 0",
                  "        || CALCULATE (",
                  "            [Gross Charge - Norm],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -2, MONTH ) )",
                  "        )",
                  "            = 0",
                  "        || CALCULATE (",
                  "            [Gross Charge - Norm],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -1, MONTH ) )",
                  "        )",
                  "            = 0,",
                  "    BLANK (),",
                  "    CALCULATE (",
                  "        [Gross Charge - Norm],",
                  "        DATESBETWEEN (",
                  "            'Date Of Accounting Month'[Acctg Dte],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -3, MONTH ) ),",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Accounting Month'[Acctg Dte], -1, MONTH ) )",
                  "        )",
                  "    )",
                  ")"
                ],
                "isHidden": true
              },
              {
                "name": "Unspecifed Dx Proc Cnt",
                "expression": "CALCULATE([Proc Cnt], 'Diag Code 1'[Diag Is Unspecified]=\"Unspecified\")",
                "formatString": "0",
                "displayFolder": "Billing"
              },
              {
                "name": "Unspecified Dx Proc % of Tot",
                "expression": "DIVIDE([Unspecifed Dx Proc Cnt], [Proc Cnt], BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Billing"
              },
              {
                "name": "Total Units - Norm/Case",
                "expression": "DIVIDE([Total Units - Norm],[Total Cases],BLANK())",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Patient Cnt",
                "expression": "DISTINCTCOUNT(_Billing[d_patient_sk])",
                "displayFolder": "Utilization"
              },
              {
                "name": "Cumulative Total Cases",
                "expression": [
                  "",
                  "IF (",
                  "    MIN ( 'Date Of Service'[d_date_sk] )",
                  "        <= CALCULATE ( MAX ( '_Billing'[service_d_date_sk] ), ALL ( '_Billing' ) ),",
                  "    CALCULATE (",
                  "        [Total Cases],",
                  "        FILTER (",
                  "            ALLSELECTED ( 'Date Of Service' ),",
                  "            'Date Of Service'[Serv Dte] <= MAX ( 'Date Of Service'[Serv Dte] )",
                  "        )",
                  "    )",
                  ")"
                ],
                "formatString": "#,0",
                "displayFolder": "Utilization\\Cases"
              },
              {
                "name": "RVU/Proc",
                "expression": "DIVIDE([Total RVU], [Proc Cnt],0)",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\RVUs"
              },
              {
                "name": "Mins/Proc",
                "expression": "DIVIDE([Total Minutes],[Proc Cnt],0)",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Units/Proc",
                "expression": "DIVIDE([Total Units], [Proc Cnt],0)",
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Contr Amt/Proc",
                "expression": "DIVIDE([Contr Allowed], [Proc Cnt],0)",
                "displayFolder": "Financial\\Contractual"
              },
              {
                "name": "Net/Gross AR%",
                "expression": " DIVIDE([Net AR], [Total Balance],0)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Financial\\Payments\\Statistics"
              },
              {
                "name": "Closed Claim",
                "expression": [
                  " IF(HASONEVALUE('Account Balance Class'[Account Balance Class]),([Gross Charge] *[Closed Claim Coll %]),",
                  "SUMX(VALUES('Account Balance Class'[Account Balance Class]),([Gross Charge] * [Closed Claim Coll %])))"
                ],
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Payments\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Paid Claim",
                "expression": [
                  " IF(HASONEVALUE('Account Balance Class'[Account Balance Class]),([Gross Charge] * [Paid Claim Coll %]),",
                  "SUMX(VALUES('Account Balance Class'[Account Balance Class]),([Gross Charge] * [Paid Claim Coll %])))"
                ],
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Payments\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Gross Charge / Proc",
                "expression": "DIVIDE([Gross Charge], [Proc Cnt],0)",
                "displayFolder": "Financial\\Charges"
              },
              {
                "name": "Time Units / Proc",
                "expression": "DIVIDE([Time Units Billed],[Proc Cnt],0)",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Net Pmt / Proc",
                "expression": "DIVIDE([Net Payment], [Proc Cnt],0)",
                "displayFolder": "Financial\\Payments"
              },
              {
                "name": "Net Pmt / Unit",
                "expression": "DIVIDE([Net Payment], [Total Units], 0)",
                "formatString": "0",
                "displayFolder": "Financial\\Payments"
              },
              {
                "name": "Gross Charge / Case",
                "expression": "DIVIDE([Gross Charge], [Total Cases],0)",
                "formatString": "0",
                "displayFolder": "Financial\\Charges"
              },
              {
                "name": "Gross Charge / Unit",
                "expression": "DIVIDE([Gross Charge], [Total Units], 0)",
                "formatString": "0",
                "displayFolder": "Financial\\Charges"
              },
              {
                "name": "Bad Debt Patient Responsibility%",
                "expression": "DIVIDE([Bad Debt Writeoff],[Pat Responsibility],0)",
                "displayFolder": "Financial\\Adjustments\\Bad Debt"
              },
              {
                "name": "EM Acuity",
                "expression": [
                  "DIVIDE",
                  " ((",
                  "    CALCULATE ( [Total Cases], _Billing[cpt_code] = \"99281\" )",
                  "        * 1",
                  "        + CALCULATE ( [Total Cases], _Billing[cpt_code] = \"99282\" )",
                  "            * 2",
                  "        + CALCULATE ( [Total Cases], _Billing[cpt_code] = \"99283\" )",
                  "            * 3",
                  "        + CALCULATE ( [Total Cases], _Billing[cpt_code] = \"99284\" )",
                  "            * 4",
                  "        + CALCULATE ( [Total Cases], _Billing[cpt_code] = \"99285\" )",
                  "            * 5",
                  "        + CALCULATE ( [Total Cases], _Billing[cpt_code] = \"99291\" )",
                  "            * 6",
                  "        + CALCULATE ( [Total Cases], _Billing[cpt_code] = \"99292\" )",
                  "            * 6",
                  ")",
                  "    , [Total Cases],0)"
                ],
                "formatString": "#,0.00",
                "displayFolder": "Utilization\\Units"
              },
              {
                "name": "Paid Claims - Norm",
                "expression": [
                  "IF(HASONEVALUE('Account Balance Class'[Account Balance Class]),([Gross Charge - Norm] * [Paid Claim Coll % - Norm]),",
                  "SUMX(VALUES('Account Balance Class'[Account Balance Class]),([Gross Charge - Norm] * [Paid Claim Coll % - Norm])))"
                ],
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Closed Claim - Norm",
                "expression": [
                  " IF(HASONEVALUE('Account Balance Class'[Account Balance Class]),([Gross Charge - Norm] * [Closed Claim Coll % - Norm]),",
                  "SUMX(VALUES('Account Balance Class'[Account Balance Class]),([Gross Charge - Norm] * [Closed Claim Coll % - Norm])))"
                ],
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Financial\\Payments\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Denial % by Posting Date Denom",
                "expression": [
                  "",
                  "CALCULATE (",
                  "    [Total Cases],",
                  "    ALL ( 'Date Of Posting' ),",
                  "    ALL ( 'Date Of Service' ),",
                  "    ALL ( 'Denial Code' ),",
                  "    'date of Service',",
                  "    DATESBETWEEN (",
                  "        'date of service'[Serv Month Start Date],",
                  "        FIRSTDATE ( 'date of Posting'[Posting Dte] ),",
                  "        LASTDATE ( 'date of Posting'[Posting Dte] )",
                  "    )",
                  ")"
                ],
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "Denial % by Posting Date",
                "expression": [
                  "",
                  "        DIVIDE ( [Denial Cnt], '_billing'[Denial % by Posting Date Denom], 0 )"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "Critical Care Case Cnt",
                "expression": " CALCULATE([Total Cases], 'CPT Code'[CPT Code]=\"99291\")",
                "isHidden": true,
                "displayFolder": "Utilization\\Cases\\Statistics"
              },
              {
                "name": "ED Critical Case 99291 %",
                "expression": "CALCULATE(DIVIDE([Critical Care Case Cnt], [Total Cases], 0), 'Facility'[Fac LOB]=\"ED\")",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Utilization\\Cases\\Statistics"
              },
              {
                "name": "Denial % by T3M Posting Month Denom",
                "expression": [
                  "",
                  "DIVIDE (",
                  "    CALCULATE (",
                  "        [Total Cases],",
                  "        ALL ( 'Date Of Posting' ),",
                  "        ALL ( 'Date Of Service' ),",
                  "        ALL ( 'Denial Code' ),",
                  "        'date of Service',",
                  "        DATESBETWEEN (",
                  "            'date of service'[Serv Month Start Date],",
                  "            FIRSTDATE ( DATEADD ( 'date of Posting'[Posting Month Start Date], -3, MONTH ) ),",
                  "            FIRSTDATE ( DATEADD ( 'date of Posting'[Posting Month Start Date], -1, MONTH ) )",
                  "        )",
                  "    ),",
                  "    3,",
                  "    0",
                  ")"
                ],
                "formatString": "#,0.00",
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "Denial % by T3M Posting Month",
                "expression": [
                  "",
                  "        DIVIDE ( [Denial Cnt], '_billing'[Denial % by T3M Posting Month Denom], 0 )"
                ],
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Operational\\Denials"
              },
              {
                "name": "Phy Comp Elig Proc Cnt",
                "expression": "[CPT Line Cnt] -  [Nurse Proc Lvl 1 Cnt]",
                "displayFolder": "Utilization\\Procedures\\Productivity"
              },
              {
                "name": "Paid Claim/Unit",
                "expression": " DIVIDE ( [Paid Claim], [Total Units - Norm], 0 )",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Financial\\Payments\\Statistics",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Paid Claim/Unit Mode",
                "expression": [
                  "",
                  "IF (",
                  "    MINX (",
                  "        TOPN (",
                  "            1,",
                  "            GROUPBY (",
                  "                ADDCOLUMNS ( VALUES ( _Billing[Encounter Num] ), \"Measure\", [Paid Claim/Unit] ),",
                  "                [Measure],",
                  "                \"Frequency\", SUMX ( CURRENTGROUP (), 1 )",
                  "            ),",
                  "            [Frequency]",
                  "        ),",
                  "        [Frequency]",
                  "    )",
                  "        < 2,",
                  "    BLANK (),",
                  "    MINX (",
                  "        TOPN (",
                  "            1,",
                  "            GROUPBY (",
                  "                ADDCOLUMNS ( VALUES ( _Billing[Encounter Num] ), \"Measure\", [Paid Claim/Unit] ),",
                  "                [Measure],",
                  "                \"Frequency\", SUMX ( CURRENTGROUP (), 1 )",
                  "            ),",
                  "            [Frequency]",
                  "        ),",
