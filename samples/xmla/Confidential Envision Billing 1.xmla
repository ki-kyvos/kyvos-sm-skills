          {
            "name": "_Net Revenue",
            "columns": [
              {
                "name": "Billing System",
                "dataType": "string",
                "isHidden": true,
                "sourceColumn": "Billing System"
              },
              {
                "name": "Encounter Num",
                "dataType": "string",
                "isHidden": true,
                "sourceColumn": "Encounter Num"
              },
              {
                "name": "Account Balance Class",
                "dataType": "string",
                "isHidden": true,
                "sourceColumn": "Account Balance Class"
              },
              {
                "name": "d_patient_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "d_patient_sk"
              },
              {
                "name": "service_d_date_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "service_d_date_sk"
              },
              {
                "name": "d_facility_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "d_facility_sk"
              },
              {
                "name": "primary_d_payer_product_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "primary_d_payer_product_sk"
              },
              {
                "name": "primary_d_insurance_sk",
                "dataType": "int64",
                "isHidden": true,
                "sourceColumn": "primary_d_insurance_sk"
              },
              {
                "name": "predicted_revenue_amt",
                "dataType": "double",
                "isHidden": true,
                "sourceColumn": "predicted_revenue_amt"
              },
              {
                "type": "calculated",
                "name": "billingsystem_encounternum",
                "dataType": "string",
                "isDataTypeInferred": true,
                "isHidden": true,
                "expression": "CONCATENATE([billing system], CONCATENATE(\"-\", '_Net Revenue'[Encounter Num]))"
              }
            ],
            "partitions": [
              {
                "name": "ZZ Net Revenue",
                "dataView": "full",
                "source": {
                  "type": "query",
                  "query": [
                    "SELECT ",
                    "\t  ",
                    " billing_system\t\t\t\t\"Billing System\"",
                    "\t,encounter_num\t\t\t\t\"Encounter Num\"",
                    "\t,balance_classification\t\t\"Account Balance Class\"",
                    "\t,d_patient_sk",
                    "\t,service_d_date_sk",
                    "\t,d_facility_sk",
                    "\t,primary_d_payer_product_sk",
                    "\t,primary_d_insurance_sk",
                    "\t,predicted_revenue_amt",
                    "",
                    "FROM EDW_INT.dbo.vf_billing_net_revenue ;"
                  ],
                  "dataSource": "EDW_INT"
                }
              }
            ],
            "measures": [
              {
                "name": "Predicted Rev",
                "expression": "SUM([predicted_revenue_amt])",
                "formatString": "\\$#,0;(\\$#,0);\\$#,0",
                "displayFolder": "Net Revenue",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Predicted Rev Rate",
                "expression": "DIVIDE([Predicted Rev],[Gross Charge],BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Net Revenue"
              },
              {
                "name": "Predicted Rev Rate - Norm",
                "expression": "DIVIDE([Predicted Rev],[Gross Charge - Norm],BLANK())",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Net Revenue"
              },
              {
                "name": "Net AR",
                "expression": "if([Predicted Rev]+[Net Payment]<0,0,[Predicted Rev]+[Net Payment])",
                "displayFolder": "Net Revenue"
              },
              {
                "name": "PredictedRevLast3Months_Norm_ServDte",
                "expression": [
                  "IF (",
                  "    CALCULATE (",
                  "        [Predicted Rev],",
                  "        FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -3, MONTH ) )",
                  "    )",
                  "        = 0",
                  "        || CALCULATE (",
                  "            [Predicted Rev],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -2, MONTH ) )",
                  "        )",
                  "            = 0",
                  "        || CALCULATE (",
                  "            [Predicted Rev],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -1, MONTH ) )",
                  "        )",
                  "            = 0,",
                  "    BLANK (),",
                  "    CALCULATE (",
                  "        [Predicted Rev],",
                  "        DATESBETWEEN (",
                  "            'Date Of Service'[Serv Dte],",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -3, MONTH ) ),",
                  "            FIRSTDATE ( DATEADD ( 'Date Of Service'[Serv Dte], -1, MONTH ) )",
                  "        )",
                  "    )",
                  ")"
                ],
                "isHidden": true
              },
              {
                "name": "Predicted Rev Target Rate",
                "expression": "DIVIDE([Predicted Rev Trailing 3 Serv-Month Avg],[Trailing 3 Serv Mnth Chg Avg - Norm],0)",
                "formatString": "#,0.00%;-#,0.00%;#,0.00%",
                "displayFolder": "Net Revenue"
              },
              {
                "name": "Predicted Rev Trailing 3 Serv-Month Avg",
                "expression": "DIVIDE([PredictedRevLast3Months_Norm_ServDte],3,0)",
                "displayFolder": "Net Revenue"
              },
              {
                "name": "Predicted Rev Per Anes Unit",
                "expression": "DIVIDE([Predicted Rev], [Total Units], 0)",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Net Revenue",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "Predicted Rev Per Anes Unit - Norm",
                "expression": "DIVIDE([Predicted Rev], [Total Units - Norm], 0)",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Net Revenue",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              }
            ],
            "annotations": [
              {
                "name": "_TM_ExtProp_DbTableName",
                "value": "ZZ Net Revenue"
              },
              {
                "name": "_TM_ExtProp_QueryDefinition",
                "value": [
                  "SELECT ",
                  "  billing_system AS [Billing System]",
                  " ,encounter_num AS [Encounter Num]",
                  " ,balance_classification AS [Account Balance Class]",
                  " ,d_patient_sk",
                  " ,service_d_date_sk",
                  " ,d_facility_sk",
                  " ,primary_d_payer_product_sk",
                  " ,primary_d_insurance_sk",
