                  "type": "query",
                  "query": [
                    "SELECT",
                    " d_account_unit_sk",
                    ",d_gl_account_sk",
                    ",fiscal_month_d_date_sk",
                    ",d_hyp_entity_hier\t\t\"OGLM Hyp Entity Hier\"",
                    ",d_hyp_department_hier\t\"OGLM Hyp Department Hier\"",
                    ",d_hyp_profit_center_hier\t\"OGLM Hyp Profit Center Hier\"",
                    ",d_hyp_account_hier",
