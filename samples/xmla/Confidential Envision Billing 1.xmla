            "tablePermissions": [
              {
                "name": "_Billing",
                "filterExpression": [
                  "",
                  "'_Billing'[d_facility_sk]",
                  "    = LOOKUPVALUE (",
                  "        'XX_ad_facility'[d_facility_sk],",
                  "        'XX_ad_facility'[ad_login], USERNAME (),",
                  "        'XX_ad_facility'[d_facility_sk], '_Billing'[d_facility_sk]",
                  "    )",
                  "    || '_Billing'[Fac LOB]",
                  "        = LOOKUPVALUE (",
                  "            'XX_ad_lob'[facility_lob],",
                  "            'XX_ad_lob'[ad_login], USERNAME (),",
                  "            'XX_ad_lob'[facility_lob], '_Billing'[Fac LOB]",
                  "        )",
                  "    || '_Billing'[d_provider_sk]",
                  "        = LOOKUPVALUE (",
                  "            'XX_ad_provider'[d_provider_sk],",
                  "            'XX_ad_provider'[ad_login], USERNAME (),",
                  "            'XX_ad_provider'[d_provider_sk], '_Billing'[d_provider_sk]",
                  "        )",
                  "    || RELATED ( 'Facility'[Oracle Profit Center] )",
                  "        = LOOKUPVALUE (",
                  "            'xx_ad_oracle_profit_center'[Profit Center],",
                  "            xx_ad_oracle_profit_center[ad_login], USERNAME (),",
                  "            xx_ad_oracle_profit_center[Profit Center], RELATED ( 'Facility'[Oracle Profit Center] )",
                  "        )",
                  "   ",
                  "\t|| RELATED ( 'Accounting Unit'[d_account_unit_sk] )",
                  "\t\t= LOOKUPVALUE (",
                  "\t\t\t'xx_ad_coau'[d_account_unit_sk],",
                  "\t\t\t'XX_ad_coau'[ad_login], USERNAME (),",
                  "\t\t\t'XX_ad_coau'[d_account_unit_sk], RELATED ( 'Accounting Unit'[d_account_unit_sk] )",
                  "\t\t)"
                ]
              },
              {
                "name": "ZZ Lawson FB Detail",
                "filterExpression": [
                  "",
                  " (",
                  "    RELATED ( 'Accounting Unit'[d_account_unit_sk] )",
                  "        = LOOKUPVALUE (",
                  "            xx_ad_facility[d_account_unit_sk],",
                  "            xx_ad_facility[ad_login], USERNAME (),",
                  "            xx_ad_facility[d_account_unit_sk], RELATED ( 'Accounting Unit'[d_account_unit_sk] )",
                  "        )",
                  "        || RELATED ( 'accounting unit'[Oracle Profit Center] )",
                  "            = LOOKUPVALUE (",
                  "                'xx_ad_oracle_profit_center'[Profit Center],",
                  "                xx_ad_oracle_profit_center[ad_login], USERNAME (),",
                  "                xx_ad_oracle_profit_center[Profit Center], RELATED ( 'accounting unit'[Oracle Profit Center] )",
                  "            )",
                  ")",
                  "    && RELATED ( 'Accounting Unit'[d_account_unit_sk] ) <> BLANK ()"
                ]
              },
              {
                "name": "ZZ Lawson GL Actuals",
                "filterExpression": [
                  "",
                  " (",
                  "    RELATED ( 'Accounting Unit'[d_account_unit_sk] )",
                  "        = LOOKUPVALUE (",
                  "            xx_ad_facility[d_account_unit_sk],",
                  "            xx_ad_facility[ad_login], USERNAME (),",
                  "            xx_ad_facility[d_account_unit_sk], RELATED ( 'Accounting Unit'[d_account_unit_sk] )",
                  "        )",
                  "        || RELATED ( 'accounting unit'[Oracle Profit Center] )",
                  "            = LOOKUPVALUE (",
