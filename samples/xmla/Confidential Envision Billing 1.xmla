              {
                "name": "QueryEditorSerialization",
                "value": [
                  "<?xml version=\"1.0\" encoding=\"UTF-16\"?><Gemini xmlns=\"QueryEditorSerialization\"><AnnotationContent><![CDATA[<RSQueryCommandText>SELECT",
                  "\taccount_num",
                  "\t,parent_num",
                  "\t,account",
                  "\t,account\t\tAS [Hyp Oracle Account]",
                  "\t,parent\t\tAS [Hyp Oracle Parent]    ",
                  "\t,alias_default\tAS [Hyp Oracle Descr]",
                  "\t,hierarchy_type\tAS [Hyp Oracle Hierachy Type]",
