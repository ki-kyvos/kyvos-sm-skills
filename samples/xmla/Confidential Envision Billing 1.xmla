                "name": "_Oracle PC",
                "dataView": "full",
                "source": {
                  "type": "query",
                  "query": [
                    "SELECT",
                    "\t   ",
                    "d_payroll_paycode_sk",
                    "\t,d_account_unit_sk",
                    "\t,d_gl_account_sk",
                    "\t,d_job_code_sk",
                    "\t,d_hyp_entity_hier\t\t\t\t\"OPC Hyp Entity Hier\"",
                    "\t,d_hyp_department_hier\t\t\t\"OPC Hyp Department Hier\"",
                    "\t,d_hyp_profit_center_hier\t\t\t\"OPC Hyp Profit Center Hier\"",
                    "\t,d_hyp_account_hier\t\t\t\"OPC Hyp Account Hier\"",
                    "\t,effective_d_date_sk",
                    "\t,pay_period_start_d_date_sk",
                    "\t,pay_period_end_d_date_sk",
                    "\t,pay_period_d_date_sk",
                    "\t,regular_payment_d_date_sk",
                    "\t,check_d_date_sk",
                    "--\t,employee_number \"OPC Employee Number\"",
                    "--\t,full_name\t\t\"OPC Full Name\"",
                    "--\t,assignment_number\t\"OPC Assignment Number\"",
                    "\t,payroll_name\t\t\t\t\"OPC Payroll Name\"",
                    "\t,gre\t\t\t\t\t\"OPC GRE\"",
                    "--\t,fein\t\t\t\"OPC FEIN\"",
                    "\t,dept_name\t\t\t\t\"OPC Dept Name\"",
                    "\t,location_code\t\t\t\t\"OPC Location Code\"",
                    "--\t,job_title\t\"OPC Job Title\"",
                    "--\t,job_class\t\"OPC Job Class\"",
                    "\t,job_code\t\t\t\t\"OPC Job Code\"",
                    "--\t,user_level\t\t\t\t\"OPC User Level\"",
                    "\t,exempt_nonexempt\t\t\t\"OPC Exempt NonExempt\"",
                    "\t,entity\t\t\t\t\t\"OPC Oracle Entity\"",
                    "\t,dept\t\t\t\t\t\"OPC Oracle Dept\"",
                    "\t,account\t\t\t\t\t\"OPC Oracle Account\"",
                    "\t,sub_account\t\t\t\t\"OPC Sub Account\"",
                    "\t,profit_center\t\t\t\t\"OPC Profit Center\"",
                    "\t,lob\t\t\t\t\t\"OPC LOB\"",
                    "\t,debit_or_credit\t\t\t\t\"OPC Debit or Credit\"",
                    "\t,amount\t",
                    "\t,hours\t",
                    "\t,rate\t\t\t\t\t\"OPC Rate\"",
                    "\t,check_number\t\t\t\t\"OPC Check Number\"",
                    "\t,classification_name\t\t\t\"OPC Classification Name\"",
                    "\t,element_name\t\t\t\t\"OPC Element Name\"",
                    "\t,costed_input_value_name\t\t\t\"OPC Costed Input Value Name\"",
                    "\t,org_payment_method_name\t\t\t\"OPC Org Payment Method Name\"",
                    "\t,payment_type_name\t\t\t\"OPC Payment Type Name\"",
                    "\t,is_restricted\t\t\t\t\"OPC Is Restricted\"",
                    "\t ,is_clinical\t\t\t\t\"OPC Is Clinical\"",
                    "",
                    "FROM EDWS_INT.dbo.vf_oracle_payroll_costing ;"
