                  ],
                  "dataSource": "EDW_INT"
                }
              }
            ],
            "measures": [
              {
                "name": "FB DB Amount",
                "expression": "SUM([db_amount])",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Lawson FB Detail",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "FB CR Amount",
                "expression": "SUM([cr_amount])",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Lawson FB Detail",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "FB DB Units",
                "expression": "SUM([db_units])",
                "formatString": "#,0",
                "displayFolder": "Lawson FB Detail"
              },
              {
                "name": "FB CR Units",
                "expression": "SUM([cr_units])",
                "formatString": "#,0",
                "displayFolder": "Lawson FB Detail"
              },
              {
                "name": "FB Amount",
                "expression": "[FB CR Amount] + [FB DB Amount]",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Lawson FB Detail",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              },
              {
                "name": "FB Units",
                "expression": "[FB DB Units] + [FB CR Units]",
                "formatString": "#,0",
                "displayFolder": "Lawson FB Detail"
              },
              {
                "name": "Budgeted ALE / Case",
                "expression": "DIVIDE( CALCULATE([FB Amount], 'GL Account'[Is ALE] = True ), CALCULATE([FB Units], 'GL Account'[GL Acct] = \"4000\"), BLANK())",
                "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
                "displayFolder": "Lawson FB Detail",
                "annotations": [
                  {
                    "name": "Format",
                    "value": "<Format Format=\"Currency\" Accuracy=\"2\"><Currency LCID=\"1033\" DisplayName=\"$ English (United States)\" Symbol=\"$\" PositivePattern=\"0\" NegativePattern=\"0\" /></Format>"
                  }
                ]
              }
