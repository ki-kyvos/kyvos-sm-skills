          "source_dataset": "sales_targets",
          "aggregation_type": "sum"
        },
        {
          "name": "amount",
          "source_dataset": "financial_reporting",
          "aggregation_type": "sum"
        },
        {
          "name": "gross_margin",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "IIF([Measures].[salesamount]=0, NULL, ([Measures].[salesamount] - [Measures].[totalproductcost]) / [Measures].[salesamount])"
        },
        {
          "name": "profit_amount",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "[Measures].[salesamount] - [Measures].[totalproductcost]"
        },
        {
          "name": "margin_percent",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "DIVIDE(([Measures].[salesamount] - [Measures].[totalproductcost]), [Measures].[salesamount], 0)"
        },
        {
          "name": "average_order_value",
          "aggregation_type": "avg",
          "is_calculated": true,
          "expression": "DIVIDE([Measures].[salesamount], [Measures].[orderquantity], 0)"
        },
        {
          "name": "high_performer_flag",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "IIF([Measures].[margin_percent]>=0.3, 1, 0)"
        }
      ],
