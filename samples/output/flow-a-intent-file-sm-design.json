      "measures": [
        {
          "name": "InternetSales_SalesAmount",
          "source_dataset": "internet_sales",
          "aggregation_type": "sum"
        },
        {
          "name": "InternetSales_ProfitMargin",
          "source_dataset": "internet_sales",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "DIVIDE(SUM([internet_sales].[salesamount]) - SUM([internet_sales].[totalproductcost]), SUM([internet_sales].[salesamount]), 0)"
        },
        {
          "name": "InternetSales_MarginPercent",
          "source_dataset": "internet_sales",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "IIF(SUM([internet_sales].[salesamount]) = 0, 0, DIVIDE(SUM([internet_sales].[salesamount]) - SUM([internet_sales].[totalproductcost]), SUM([internet_sales].[salesamount]), 0))"
        },
        {
          "name": "InternetSales_YTD_SalesAmount",
          "source_dataset": "internet_sales",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "SUM(YTD([date].[calendaryear].CurrentMember), [Measures].[InternetSales_SalesAmount])"
        },
        {
          "name": "InternetSales_QTD_SalesAmount",
          "source_dataset": "internet_sales",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "SUM(QTD([date].[calendarquarter].CurrentMember), [Measures].[InternetSales_SalesAmount])"
        },
        {
          "name": "InternetSales_MTD_SalesAmount",
          "source_dataset": "internet_sales",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "SUM(MTD([date].[monthnumberofyear].CurrentMember), [Measures].[InternetSales_SalesAmount])"
        },
        {
          "name": "InternetSales_PriorYearSales",
          "source_dataset": "internet_sales",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "([Measures].[InternetSales_SalesAmount], ParallelPeriod([date].[calendaryear], 1, [date].[calendaryear].CurrentMember))"
        },
        {
          "name": "InternetSales_YoYGrowthPercent",
          "source_dataset": "internet_sales",
          "aggregation_type": "sum",
          "is_calculated": true,
          "expression": "IIF([Measures].[InternetSales_PriorYearSales] = 0, NULL, DIVIDE([Measures].[InternetSales_SalesAmount] - [Measures].[InternetSales_PriorYearSales], [Measures].[InternetSales_PriorYearSales], 0))"
        },
